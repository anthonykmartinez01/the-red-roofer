---
import { categories } from '../../data/categories';
import { locations } from '../../data/locations';
import logoImage from '../../assets/logo.png';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { name: "Home", href: "/" },
  { name: "Calculator", href: "/calculator" },
  { name: "Gallery", href: "/gallery" },
  { name: "Contact", href: "/contact" },
];

const displayLocations = locations.slice(0, 8);
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Company Info -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2">
          <img
            src={logoImage.src}
            alt="The Red Roofer"
            width="40"
            height="40"
            class="w-8 h-8"
          />
          <span class="text-lg font-display font-bold text-white">
            The Red Roofer
          </span>
        </a>
        <p class="text-white/70 text-sm leading-relaxed">
          Expert roofing contractor serving Little Elm, TX and the DFW metroplex. Quality roof repairs, installations, inspections, and handyman services you can trust.
        </p>
        <div class="space-y-3">
          <a
            href="tel:+19402603197"
            class="flex items-center gap-2 text-white/80 hover:text-white transition-colors text-sm"
          >
            <!-- Phone Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span>(940) 260-3197</span>
          </a>
          <a
            href="mailto:theredroofer@gmail.com"
            class="flex items-center gap-2 text-white/80 hover:text-white transition-colors text-sm"
          >
            <!-- Mail Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            <span>theredroofer@gmail.com</span>
          </a>
          <div class="flex items-center gap-2 text-white/80 text-sm">
            <!-- MapPin Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <span>Little Elm, TX</span>
          </div>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-display font-bold uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-2">
          {categories.map((category) => (
            <li>
              <a
                href={`/category/${category.slug}`}
                class="text-white/70 hover:text-white transition-colors text-sm"
              >
                {category.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service Areas -->
      <div>
        <h3 class="text-sm font-display font-bold uppercase tracking-wider mb-4">Service Areas</h3>
        <div class="grid grid-cols-2 gap-x-4 gap-y-2">
          {displayLocations.map((location) => (
            <a
              href={`/${location.slug}`}
              class="flex items-center gap-1.5 text-white/70 hover:text-white transition-colors text-sm"
            >
              <!-- CheckCircle Icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path d="m9 11 3 3L22 4"></path></svg>
              <span>{location.name}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-display font-bold uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/70 hover:text-white transition-colors text-sm"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <a
            href="/contact"
            class="inline-block bg-[hsl(14,100%,57%)] text-white font-bold text-sm px-5 py-2.5 rounded-lg hover:bg-[hsl(14,100%,50%)] transition-colors"
          >
            Get A Free Quote
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/50">
        <p>&copy; {currentYear} The Red Roofer. All rights reserved.</p>
        <div class="flex items-center gap-4">
          <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
          <a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>
