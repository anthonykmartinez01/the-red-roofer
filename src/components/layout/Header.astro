---
import { locations } from '../../data/locations';
import logoImage from '../../assets/logo.png';

const pathname = Astro.url.pathname;

const navServicesItems = [
  { name: "Roof Repair", href: "/service/roof-repair" },
  { name: "Roof Installation", href: "/service/roof-installation" },
  { name: "Roof Inspection", href: "/service/roof-inspection" },
  { name: "Roof Damage Repair", href: "/service/roof-damage-repair" },
  { name: "Storm & Wind Damage", href: "/service/storm-wind-damage-repair" },
  { name: "Gutter Cleaning", href: "/service/gutter-cleaning" },
  { name: "Gutter Repairs", href: "/service/gutter-repairs" },
  { name: "Exterior Painting", href: "/service/exterior-painting" },
  { name: "Handyman Services", href: "/category/handyman" },
];

const navigation = [
  { name: "Home", href: "/", hasDropdown: null },
  { name: "Services", href: "#", hasDropdown: "services" },
  { name: "Calculator", href: "/calculator", hasDropdown: null },
  { name: "Gallery", href: "/gallery", hasDropdown: null },
  { name: "Service Areas", href: "#", hasDropdown: "areas" },
  { name: "Contact", href: "/contact", hasDropdown: null },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!-- Mobile Header -->
<header class="fixed top-0 left-0 right-0 z-50 md:hidden bg-background/98 border-b border-border safe-area-top">
  <div class="flex items-center justify-between p-2.5 sm:p-3 gap-2">
    <a
      href="/contact"
      class="flex-1 py-3 h-auto min-h-[44px] inline-flex items-center justify-center gap-2 whitespace-nowrap font-bold uppercase tracking-wide ring-offset-background transition-all duration-300 bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] text-xs sm:text-sm touch-target"
    >
      Get Free Quote
    </a>
    <a
      href="tel:+19402603197"
      class="flex items-center justify-center gap-1 py-3 px-2 sm:px-3 min-h-[44px] bg-background border-2 border-border text-accent font-bold tracking-tight text-[11px] sm:text-xs hover:bg-muted transition-colors whitespace-nowrap touch-target"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 flex-shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      <span class="hidden xs:inline">+1 940-260-3197</span>
      <span class="xs:hidden">Call</span>
    </a>
    <button
      type="button"
      data-mobile-menu-toggle
      class="p-3 min-h-[44px] min-w-[44px] text-accent hover:text-accent/80 transition-colors duration-200 touch-target flex items-center justify-center"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg data-hamburger-icon xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
      <svg data-close-icon class="hidden h-6 w-6 sm:h-7 sm:w-7" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
    </button>
  </div>

  <!-- Mobile Navigation Menu -->
  <div
    data-mobile-menu
    class="max-h-0 overflow-y-auto transition-all duration-200 bg-background"
  >
    <div class="flex flex-col gap-1 px-3 border-t border-border pt-3 pb-4">
      {navigation.map((item) => (
        item.hasDropdown ? (
          <div data-mobile-dropdown>
            <button
              data-mobile-dropdown-toggle
              class:list={[
                "w-full px-4 py-3.5 min-h-[48px] flex items-center justify-between text-base font-bold uppercase tracking-wide transition-colors duration-200 touch-target",
                "text-foreground hover:text-accent hover:bg-muted"
              ]}
            >
              <span>{item.name}</span>
              <svg data-chevron class="w-4 h-4 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
            </button>
            <div data-mobile-dropdown-content class="max-h-0 overflow-hidden transition-all duration-200">
              <div class="pl-4 py-1">
                {item.hasDropdown === "services" && navServicesItems.map(svc => (
                  <a href={svc.href} class="block px-4 py-2.5 text-sm font-medium text-foreground hover:text-accent">
                    {svc.name}
                  </a>
                ))}
                {item.hasDropdown === "areas" && locations.map(loc => (
                  <a href={`/location/${loc.slug}`} class="block px-4 py-2.5 text-sm font-medium text-foreground hover:text-accent">
                    {loc.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              "px-4 py-3.5 min-h-[48px] flex items-center text-base font-bold uppercase tracking-wide transition-colors duration-200 touch-target",
              isActive(item.href) ? "text-accent bg-muted" : "text-foreground hover:text-accent hover:bg-muted"
            ]}
          >
            {item.name}
          </a>
        )
      ))}
    </div>
  </div>
</header>

<!-- Desktop Header -->
<header class="fixed top-0 left-0 right-0 z-50 bg-background/98 border-b border-border hidden md:block">
  <nav data-desktop-nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img
          src={logoImage.src}
          alt="The Red Roofer Logo"
          width="48"
          height="48"
          class="w-12 h-12 object-cover transition-transform duration-200 group-hover:scale-105"
        />
        <div class="hidden sm:block">
          <span class="font-[family-name:var(--font-display)] font-extrabold text-xl text-foreground tracking-tight uppercase">The Red Roofer</span>
          <span class="block text-xs text-muted-foreground font-medium uppercase tracking-wide">Roofing & Handyman</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navigation.map((item) => (
          <div class="relative">
            {item.hasDropdown ? (
              <div data-desktop-dropdown class="relative">
                <button
                  data-desktop-dropdown-toggle
                  class:list={[
                    "flex items-center gap-1 px-4 py-2 text-sm font-bold uppercase tracking-wide transition-colors duration-200",
                    "text-foreground hover:text-accent"
                  ]}
                >
                  <span>{item.name}</span>
                  <svg data-chevron class="w-3.5 h-3.5 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
                </button>
                <div
                  data-desktop-dropdown-content
                  class="hidden absolute top-full right-0 mt-2 bg-background border border-border shadow-xl z-[100] rounded-md"
                >
                  {item.hasDropdown === "services" && (
                    <div class="flex flex-col p-3 min-w-[220px]">
                      {navServicesItems.map(svc => (
                        <a href={svc.href} class="block px-3 py-2 text-sm font-medium text-foreground hover:text-accent hover:bg-muted rounded transition-colors whitespace-nowrap">
                          {svc.name}
                        </a>
                      ))}
                    </div>
                  )}
                  {item.hasDropdown === "areas" && (
                    <div class="grid grid-cols-3 gap-x-2 gap-y-0 p-4 min-w-[520px]">
                      {locations.map(loc => (
                        <a href={`/location/${loc.slug}`} class="block px-3 py-2 text-sm font-medium text-foreground hover:text-accent hover:bg-muted rounded transition-colors whitespace-nowrap">
                          {loc.name}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class:list={[
                  "px-4 py-2 text-sm font-bold uppercase tracking-wide transition-colors duration-200",
                  isActive(item.href) ? "text-accent" : "text-foreground hover:text-accent"
                ]}
              >
                {item.name}
              </a>
            )}
          </div>
        ))}
      </div>

      <!-- Phone CTA -->
      <div class="flex items-center gap-4">
        <a
          href="tel:+19402603197"
          class="hidden sm:flex items-center gap-2 text-foreground font-bold hover:text-accent transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <span>+1 940-260-3197</span>
        </a>
        <a
          href="/contact"
          class="hidden md:flex inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-bold uppercase tracking-wide ring-offset-background transition-all duration-300 bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] h-11 px-5 py-2"
        >
          Get Free Quote
        </a>

        <!-- Tablet menu button -->
        <button
          type="button"
          data-tablet-menu-toggle
          class="hidden md:block lg:hidden p-2.5 bg-muted text-foreground hover:bg-accent hover:text-accent-foreground transition-colors duration-200"
          aria-label="Toggle menu"
        >
          <svg data-tablet-hamburger xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
          <svg data-tablet-close class="hidden h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
        </button>
      </div>
    </div>

    <!-- Tablet Navigation -->
    <div
      data-tablet-menu
      class="lg:hidden max-h-0 overflow-hidden transition-all duration-200"
    >
      <div class="flex flex-col gap-1 pt-4 border-t border-border pb-6">
        {navigation.map((item) => (
          item.hasDropdown ? (
            <div data-tablet-dropdown>
              <button
                data-tablet-dropdown-toggle
                class="w-full px-4 py-3 flex items-center justify-between text-base font-bold uppercase tracking-wide transition-colors duration-200 text-foreground hover:text-accent hover:bg-muted"
              >
                <span>{item.name}</span>
                <svg data-chevron class="w-4 h-4 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
              </button>
              <div data-tablet-dropdown-content class="max-h-0 overflow-hidden transition-all duration-200">
                <div class="pl-4 py-1">
                  {item.hasDropdown === "services" && navServicesItems.map(svc => (
                    <a href={svc.href} class="block px-4 py-2.5 text-sm font-medium text-foreground hover:text-accent">{svc.name}</a>
                  ))}
                  {item.hasDropdown === "areas" && locations.map(loc => (
                    <a href={`/location/${loc.slug}`} class="block px-4 py-2.5 text-sm font-medium text-foreground hover:text-accent">{loc.name}</a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                "px-4 py-3 text-base font-bold uppercase tracking-wide transition-colors duration-200",
                isActive(item.href) ? "text-accent bg-muted" : "text-foreground hover:text-accent hover:bg-muted"
              ]}
            >
              {item.name}
            </a>
          )
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuToggle = document.querySelector('[data-mobile-menu-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const hamburgerIcon = document.querySelector('[data-hamburger-icon]');
  const closeIcon = document.querySelector('[data-close-icon]');

  if (mobileMenuToggle && mobileMenu && hamburgerIcon && closeIcon) {
    mobileMenuToggle.addEventListener('click', () => {
      const isOpen = mobileMenu.style.maxHeight && mobileMenu.style.maxHeight !== '0px';
      if (isOpen) {
        mobileMenu.style.maxHeight = '0px';
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        mobileMenuToggle.setAttribute('aria-expanded', 'false');
        mobileMenuToggle.setAttribute('aria-label', 'Open menu');
      } else {
        mobileMenu.style.maxHeight = '80vh';
        mobileMenu.style.paddingBottom = '1rem';
        hamburgerIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        mobileMenuToggle.setAttribute('aria-expanded', 'true');
        mobileMenuToggle.setAttribute('aria-label', 'Close menu');
      }
    });
  }

  // Mobile dropdown toggles
  document.querySelectorAll('[data-mobile-dropdown-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('[data-mobile-dropdown]');
      if (!parent) return;
      const content = parent.querySelector('[data-mobile-dropdown-content]') as HTMLElement;
      const chevron = btn.querySelector('[data-chevron]');
      if (!content) return;

      const isOpen = content.style.maxHeight && content.style.maxHeight !== '0px';
      if (isOpen) {
        content.style.maxHeight = '0px';
        chevron?.classList.remove('rotate-180');
        btn.classList.remove('text-accent', 'bg-muted');
      } else {
        content.style.maxHeight = '2000px';
        chevron?.classList.add('rotate-180');
        btn.classList.add('text-accent', 'bg-muted');
      }
    });
  });

  // Desktop dropdown toggles
  const desktopNav = document.querySelector('[data-desktop-nav]');

  document.querySelectorAll('[data-desktop-dropdown]').forEach((dropdown) => {
    const toggle = dropdown.querySelector('[data-desktop-dropdown-toggle]');
    const content = dropdown.querySelector('[data-desktop-dropdown-content]');
    const chevron = toggle?.querySelector('[data-chevron]');
    if (!toggle || !content) return;

    toggle.addEventListener('click', () => {
      // Close all other dropdowns first
      document.querySelectorAll('[data-desktop-dropdown-content]').forEach((other) => {
        if (other !== content) {
          other.classList.add('hidden');
          other.closest('[data-desktop-dropdown]')?.querySelector('[data-chevron]')?.classList.remove('rotate-180');
        }
      });
      content.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });
  });

  // Close desktop dropdowns on outside mousedown (matches original React behavior)
  document.addEventListener('mousedown', (e) => {
    if (desktopNav && desktopNav.contains(e.target as Node)) return;
    document.querySelectorAll('[data-desktop-dropdown-content]').forEach((content) => {
      content.classList.add('hidden');
      content.closest('[data-desktop-dropdown]')?.querySelector('[data-chevron]')?.classList.remove('rotate-180');
    });
  });

  // Tablet menu toggle
  const tabletMenuToggle = document.querySelector('[data-tablet-menu-toggle]');
  const tabletMenu = document.querySelector('[data-tablet-menu]') as HTMLElement;
  const tabletHamburger = document.querySelector('[data-tablet-hamburger]');
  const tabletClose = document.querySelector('[data-tablet-close]');

  if (tabletMenuToggle && tabletMenu && tabletHamburger && tabletClose) {
    tabletMenuToggle.addEventListener('click', () => {
      const isOpen = tabletMenu.style.maxHeight && tabletMenu.style.maxHeight !== '0px';
      if (isOpen) {
        tabletMenu.style.maxHeight = '0px';
        tabletMenu.style.overflow = 'hidden';
        tabletHamburger.classList.remove('hidden');
        tabletClose.classList.add('hidden');
      } else {
        tabletMenu.style.maxHeight = '600px';
        tabletMenu.style.overflow = 'auto';
        tabletHamburger.classList.add('hidden');
        tabletClose.classList.remove('hidden');
      }
    });
  }

  // Tablet dropdown toggles
  document.querySelectorAll('[data-tablet-dropdown-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('[data-tablet-dropdown]');
      if (!parent) return;
      const content = parent.querySelector('[data-tablet-dropdown-content]') as HTMLElement;
      const chevron = btn.querySelector('[data-chevron]');
      if (!content) return;

      const isOpen = content.style.maxHeight && content.style.maxHeight !== '0px';
      if (isOpen) {
        content.style.maxHeight = '0px';
        chevron?.classList.remove('rotate-180');
        btn.classList.remove('text-accent', 'bg-muted');
      } else {
        content.style.maxHeight = '2000px';
        chevron?.classList.add('rotate-180');
        btn.classList.add('text-accent', 'bg-muted');
      }
    });
  });
</script>
