---
import { locations } from '../../data/locations';
import logoImage from '../../assets/logo.png';

const pathname = Astro.url.pathname;

const serviceDropdownItems = [
  { name: "Roof Repair", href: "/category/roof-repair" },
  { name: "Roof Installation", href: "/category/roof-installation" },
  { name: "Roof Inspection", href: "/category/roof-inspection" },
  { name: "Roof Damage Repair", href: "/category/roof-damage-repair" },
  { name: "Storm & Wind Damage", href: "/category/storm-wind-damage" },
  { name: "Gutter Cleaning", href: "/category/gutter-cleaning" },
  { name: "Gutter Repairs", href: "/category/gutter-repairs" },
  { name: "Exterior Painting", href: "/category/exterior-painting" },
  { name: "Handyman Services", href: "/category/handyman" },
];

const navItems = [
  { name: "Home", href: "/" },
  { name: "Services", href: "#", dropdown: serviceDropdownItems },
  { name: "Calculator", href: "/calculator" },
  { name: "Gallery", href: "/gallery" },
  { name: "Service Areas", href: "#", dropdown: locations.map(l => ({ name: l.name, href: `/${l.slug}` })) },
  { name: "Contact", href: "/contact" },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border">
  <!-- Mobile Header -->
  <div class="md:hidden">
    <div class="flex items-center justify-between px-4 h-14">
      <!-- Get Free Quote Button -->
      <a
        href="/contact"
        class="bg-[hsl(14,100%,57%)] text-white font-bold text-xs px-3 py-2 rounded-lg hover:bg-[hsl(14,100%,50%)] transition-colors"
      >
        Get Free Quote
      </a>

      <!-- Phone Button -->
      <a
        href="tel:+19402603197"
        class="flex items-center gap-1.5 text-primary font-semibold text-sm"
        aria-label="Call The Red Roofer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        <span>(940) 260-3197</span>
      </a>

      <!-- Hamburger Menu Button -->
      <button
        data-mobile-menu-toggle
        class="p-2 text-primary"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg data-hamburger-icon xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
        <svg data-close-icon class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
    </div>

    <!-- Mobile Menu Dropdown -->
    <nav
      data-mobile-menu
      class="hidden border-t border-border bg-white max-h-[calc(100vh-3.5rem)] overflow-y-auto"
    >
      <div class="px-4 py-3 space-y-1">
        {navItems.map((item) => (
          item.dropdown ? (
            <div data-mobile-dropdown class="border-b border-border/50 last:border-0">
              <button
                data-mobile-dropdown-toggle
                class="flex items-center justify-between w-full py-3 text-sm font-medium text-foreground"
              >
                <span>{item.name}</span>
                <svg data-chevron class="w-4 h-4 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
              </button>
              <div data-mobile-dropdown-content class="hidden pb-2 pl-4 space-y-1">
                {item.dropdown.map((sub) => (
                  <a
                    href={sub.href}
                    class:list={[
                      "block py-2 text-sm transition-colors",
                      isActive(sub.href) ? "text-accent font-medium" : "text-muted-foreground hover:text-foreground"
                    ]}
                  >
                    {sub.name}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                "block py-3 text-sm font-medium border-b border-border/50 last:border-0 transition-colors",
                isActive(item.href) ? "text-accent" : "text-foreground hover:text-accent"
              ]}
            >
              {item.name}
            </a>
          )
        ))}

        <div class="pt-3">
          <a
            href="/contact"
            class="block w-full text-center bg-[hsl(14,100%,57%)] text-white font-bold py-3 rounded-lg hover:bg-[hsl(14,100%,50%)] transition-colors"
          >
            Get A Free Quote
          </a>
        </div>
      </div>
    </nav>
  </div>

  <!-- Desktop Header -->
  <div class="hidden md:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 lg:h-20">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 shrink-0">
          <img
            src={logoImage.src}
            alt="The Red Roofer"
            width="40"
            height="40"
            class="w-8 h-8 lg:w-10 lg:h-10"
          />
          <span class="text-lg lg:text-xl font-display font-bold text-primary">
            The Red Roofer
          </span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="flex items-center gap-1 lg:gap-2">
          {navItems.map((item) => (
            item.dropdown ? (
              <div data-desktop-dropdown class="relative">
                <button
                  data-desktop-dropdown-toggle
                  class:list={[
                    "flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-md transition-colors",
                    pathname.startsWith('/category') && item.name === 'Services'
                      ? "text-accent"
                      : "text-foreground hover:text-accent hover:bg-secondary"
                  ]}
                >
                  <span>{item.name}</span>
                  <svg data-chevron class="w-4 h-4 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
                </button>
                <div
                  data-desktop-dropdown-content
                  class="hidden absolute top-full left-0 mt-1 w-56 bg-white rounded-lg shadow-lg border border-border py-2 z-50"
                >
                  {item.dropdown.map((sub) => (
                    <a
                      href={sub.href}
                      class:list={[
                        "block px-4 py-2 text-sm transition-colors",
                        isActive(sub.href) ? "text-accent font-medium bg-secondary/50" : "text-foreground hover:text-accent hover:bg-secondary/50"
                      ]}
                    >
                      {sub.name}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class:list={[
                  "px-3 py-2 text-sm font-medium rounded-md transition-colors",
                  isActive(item.href) ? "text-accent" : "text-foreground hover:text-accent hover:bg-secondary"
                ]}
              >
                {item.name}
              </a>
            )
          ))}
        </nav>

        <!-- Desktop CTA -->
        <div class="flex items-center gap-3 shrink-0">
          <a
            href="tel:+19402603197"
            class="flex items-center gap-1.5 text-primary font-semibold text-sm hover:text-accent transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span>(940) 260-3197</span>
          </a>
          <a
            href="/contact"
            class="bg-[hsl(14,100%,57%)] text-white font-bold text-sm px-4 py-2 rounded-lg hover:bg-[hsl(14,100%,50%)] transition-colors"
          >
            Get Free Quote
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuToggle = document.querySelector('[data-mobile-menu-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const hamburgerIcon = document.querySelector('[data-hamburger-icon]');
  const closeIcon = document.querySelector('[data-close-icon]');

  if (mobileMenuToggle && mobileMenu && hamburgerIcon && closeIcon) {
    mobileMenuToggle.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      mobileMenuToggle.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  // Mobile dropdown toggles
  document.querySelectorAll('[data-mobile-dropdown-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('[data-mobile-dropdown]');
      if (!parent) return;
      const content = parent.querySelector('[data-mobile-dropdown-content]');
      const chevron = btn.querySelector('[data-chevron]');
      if (!content) return;

      content.classList.toggle('hidden');
      if (chevron) {
        chevron.classList.toggle('rotate-180');
      }
    });
  });

  // Desktop dropdown toggles
  document.querySelectorAll('[data-desktop-dropdown]').forEach((dropdown) => {
    const toggle = dropdown.querySelector('[data-desktop-dropdown-toggle]');
    const content = dropdown.querySelector('[data-desktop-dropdown-content]');
    const chevron = toggle?.querySelector('[data-chevron]');
    if (!toggle || !content) return;

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      // Close all other dropdowns first
      document.querySelectorAll('[data-desktop-dropdown-content]').forEach((other) => {
        if (other !== content) {
          other.classList.add('hidden');
          other.closest('[data-desktop-dropdown]')?.querySelector('[data-chevron]')?.classList.remove('rotate-180');
        }
      });
      content.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });

    // Close on mouse leave
    dropdown.addEventListener('mouseleave', () => {
      content.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
    });
  });

  // Close desktop dropdowns when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll('[data-desktop-dropdown-content]').forEach((content) => {
      content.classList.add('hidden');
      content.closest('[data-desktop-dropdown]')?.querySelector('[data-chevron]')?.classList.remove('rotate-180');
    });
  });
</script>
