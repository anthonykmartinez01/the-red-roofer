---
import '../../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import ChatWidget from '../ChatWidget.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  schemaJson?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-image.png',
  noIndex = false,
  schemaJson,
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "RoofingContractor", "HomeAndConstructionBusiness"],
  "@id": "https://theredroofer.com/#business",
  "name": "The Red Roofer",
  "alternateName": "The Red Roofer Roofing & Handyman",
  "url": "https://theredroofer.com/",
  "logo": "https://theredroofer.com/favicon.png",
  "image": "https://theredroofer.com/og-image.png",
  "description": "The Red Roofer is a roofing contractor in Little Elm, TX serving the DFW metroplex with expert roof repairs, installations, inspections, gutter services, handyman work, fencing, landscaping, and chimney services.",
  "telephone": "+1-940-260-3197",
  "email": "theredroofer@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Little Elm",
    "addressRegion": "TX",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 33.1626,
    "longitude": -96.9375
  },
  "priceRange": "$$",
  "paymentAccepted": "Cash, Credit Card",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "07:00",
      "closes": "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "08:00",
      "closes": "17:00"
    }
  ],
  "sameAs": ["https://maps.app.goo.gl/wjJBf8ppToSWBGyi7"]
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#194D32" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.png" type="image/png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Additional Schema -->
    {schemaJson && (
      <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />
    )}

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G55QPPJV8H"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G55QPPJV8H');
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground font-sans antialiased">
    <Header />
    <main class="flex-1 pt-14 sm:pt-16 md:pt-20">
      <slot />
    </main>
    <Footer />
    <ChatWidget />
  </body>
</html>
