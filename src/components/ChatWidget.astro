---
import logo from '../assets/logo.png';
---

<!-- Chat Widget -->
<div id="chat-widget" class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 z-50 safe-area-bottom safe-area-right">
  <!-- Floating Message Bubble -->
  <div
    id="chat-bubble"
    class="absolute bottom-16 sm:bottom-20 right-0 w-56 sm:w-72 bg-background border border-border shadow-lg rounded-lg p-3 sm:p-4 animate-fade-in"
  >
    <button
      id="bubble-close"
      class="absolute top-2 right-2 p-1 min-h-[32px] min-w-[32px] text-muted-foreground hover:text-foreground transition-colors touch-target flex items-center justify-center"
      aria-label="Close message"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <div class="flex gap-2 sm:gap-3 pr-6">
      <img src={logo.src} alt="The Red Roofer" class="w-8 h-8 sm:w-10 sm:h-10 rounded-full object-cover flex-shrink-0" width="40" height="40" />
      <p class="text-xs sm:text-sm text-foreground leading-relaxed">
        Shoot me any questions and I will get back to you as soon as I have a minute
      </p>
    </div>
    <!-- Speech bubble tail -->
    <div class="absolute -bottom-2 right-6 w-4 h-4 bg-background border-r border-b border-border transform rotate-45"></div>
  </div>

  <!-- Chat Window -->
  <div
    id="chat-panel"
    class="hidden absolute bottom-16 sm:bottom-20 right-0 w-[calc(100vw-2rem)] sm:w-80 max-w-80 bg-background border-2 border-border shadow-2xl rounded-lg overflow-hidden animate-fade-in"
  >
    <!-- Header -->
    <div
      id="chat-header"
      class="bg-primary p-3 sm:p-4 flex items-center justify-between cursor-pointer min-h-[56px] touch-target"
    >
      <div class="flex items-center gap-2 sm:gap-3">
        <img src={logo.src} alt="The Red Roofer" class="w-8 h-8 sm:w-10 sm:h-10 rounded-full object-cover border-2 border-primary-foreground/20" width="40" height="40" />
        <h3 class="font-bold text-primary-foreground text-sm sm:text-base">Have a question?</h3>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" class="text-primary-foreground size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" /></svg>
    </div>

    <!-- Content -->
    <div class="p-3 sm:p-4 max-h-[60vh] overflow-y-auto">
      <!-- Chat Bubble Message -->
      <div id="chat-body-form">
        <div class="flex gap-2 mb-3 sm:mb-4">
          <img src={logo.src} alt="The Red Roofer" class="w-6 h-6 sm:w-8 sm:h-8 rounded-full object-cover flex-shrink-0" width="32" height="32" />
          <div class="bg-secondary p-2 sm:p-3 rounded-lg rounded-tl-none">
            <p class="text-xs sm:text-sm text-foreground italic">
              This text goes straight to my personal phone. I will make sure to get back to you the second I'm free!
            </p>
          </div>
        </div>

        <form id="chat-form" class="space-y-2 sm:space-y-3">
          <input
            type="text"
            name="name"
            placeholder="Name"
            required
            class="w-full px-3 py-2.5 text-base border-2 border-border rounded-md bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-accent h-11 touch-target"
          />
          <input
            type="tel"
            name="phone"
            placeholder="Phone"
            required
            class="w-full px-3 py-2.5 text-base border-2 border-border rounded-md bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-accent h-11 touch-target"
          />
          <textarea
            name="message"
            placeholder="I want to know more"
            rows="2"
            class="w-full px-3 py-2.5 text-base border-2 border-border rounded-md bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-accent resize-none touch-target"
          ></textarea>
          <p class="text-[10px] sm:text-xs text-muted-foreground leading-relaxed">
            By submitting you agree to receive SMS for the provided channel. Rates may be applied.
          </p>
          <button
            type="submit"
            id="chat-submit"
            class="w-full min-h-[44px] inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-bold uppercase tracking-wide ring-offset-background transition-all duration-300 bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] touch-target"
          >
            <span id="chat-submit-text">Send :)</span>
            <svg id="chat-submit-icon" xmlns="http://www.w3.org/2000/svg" class="size-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 2L11 13" /><path stroke-linecap="round" stroke-linejoin="round" d="M22 2L15 22l-4-9-9-4 20-7z" /></svg>
          </button>
        </form>
      </div>

      <!-- Success State -->
      <div id="chat-success" class="hidden text-center py-4 sm:py-6">
        <div class="w-10 h-10 sm:w-12 sm:h-12 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-2 sm:mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="text-accent size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
        </div>
        <h4 class="font-bold text-foreground mb-1 text-sm sm:text-base">Thank You!</h4>
        <p class="text-xs sm:text-sm text-muted-foreground">We'll text you shortly.</p>
      </div>
    </div>
  </div>

  <!-- Toggle Button -->
  <button
    id="chat-toggle"
    class="w-14 h-14 bg-accent hover:bg-accent/90 text-accent-foreground rounded-full shadow-lg flex items-center justify-center transition-all duration-300 hover:scale-110 touch-target"
    aria-label="Open chat"
  >
    <svg id="chat-icon-open" xmlns="http://www.w3.org/2000/svg" class="size-[22px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
    <svg id="chat-icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden size-[22px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>

  <!-- Floating Get Free Quote Button -->
  <a
    id="floating-quote-btn"
    href="/contact"
    class="hidden absolute right-16 sm:right-20 bottom-1 sm:bottom-2 uppercase tracking-tight font-bold text-xs sm:text-sm shadow-lg min-h-[44px] touch-target inline-flex items-center justify-center gap-2 whitespace-nowrap ring-offset-background transition-all duration-300 bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] px-4 py-2 animate-fade-in"
  >
    Get Free Quote
  </a>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.2s ease-out;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('chat-toggle') as HTMLButtonElement;
    const panel = document.getElementById('chat-panel') as HTMLDivElement;
    const bubble = document.getElementById('chat-bubble') as HTMLDivElement;
    const bubbleClose = document.getElementById('bubble-close') as HTMLButtonElement;
    const chatHeader = document.getElementById('chat-header') as HTMLDivElement;
    const form = document.getElementById('chat-form') as HTMLFormElement;
    const bodyForm = document.getElementById('chat-body-form') as HTMLDivElement;
    const success = document.getElementById('chat-success') as HTMLDivElement;
    const floatingBtn = document.getElementById('floating-quote-btn') as HTMLAnchorElement;
    const iconOpen = document.getElementById('chat-icon-open') as SVGElement;
    const iconClose = document.getElementById('chat-icon-close') as SVGElement;
    const submitBtn = document.getElementById('chat-submit') as HTMLButtonElement;
    const submitText = document.getElementById('chat-submit-text') as HTMLSpanElement;
    const submitIcon = document.getElementById('chat-submit-icon') as SVGElement;

    let panelOpen = false;

    // Show speech bubble initially (hidden when chat opens or bubble dismissed)
    // Bubble is visible by default in HTML

    // Toggle chat panel
    toggle.addEventListener('click', () => {
      panelOpen = !panelOpen;
      if (panelOpen) {
        panel.classList.remove('hidden');
        bubble.classList.add('hidden');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
        toggle.setAttribute('aria-label', 'Close chat');
      } else {
        panel.classList.add('hidden');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        toggle.setAttribute('aria-label', 'Open chat');
        // Reset submitted state
        bodyForm.classList.remove('hidden');
        success.classList.add('hidden');
      }
    });

    // Close bubble
    bubbleClose.addEventListener('click', (e) => {
      e.stopPropagation();
      bubble.classList.add('hidden');
    });

    // Close panel via header click
    chatHeader.addEventListener('click', () => {
      panel.classList.add('hidden');
      panelOpen = false;
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-label', 'Open chat');
      // Reset submitted state
      bodyForm.classList.remove('hidden');
      success.classList.add('hidden');
    });

    // Show floating quote button on scroll
    window.addEventListener('scroll', () => {
      if (window.scrollY > 100 && !panelOpen) {
        floatingBtn.classList.remove('hidden');
      } else {
        floatingBtn.classList.add('hidden');
      }
    });

    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const name = (formData.get('name') as string || '').trim();
      const phone = (formData.get('phone') as string || '').trim();
      const message = (formData.get('message') as string || 'I want to know more');

      if (!name || !phone) {
        alert('Please fill in all fields');
        return;
      }

      submitBtn.disabled = true;
      submitText.textContent = 'Sending...';
      submitIcon.classList.add('hidden');

      const webhookUrl = 'https://services.leadconnectorhq.com/hooks/ks0cCYzWIf2tDiYJV3vw/webhook-trigger/fVA7RztyKm3pNWrmsYAz';

      const payload = new URLSearchParams();
      payload.append('name', name);
      payload.append('phone', phone);
      payload.append('message', message);
      payload.append('source', 'Website - Chat Widget');
      payload.append('timestamp', new Date().toISOString());

      try {
        await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          mode: 'no-cors',
          body: payload.toString(),
        });

        bodyForm.classList.add('hidden');
        success.classList.remove('hidden');
        form.reset();
      } catch (error) {
        console.error('Error submitting form:', error);
        alert('Something went wrong. Please try again.');
      } finally {
        submitBtn.disabled = false;
        submitText.textContent = 'Send :)';
        submitIcon.classList.remove('hidden');
      }
    });
  });
</script>
