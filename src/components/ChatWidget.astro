---
import logo from '../assets/logo.png';
---

<!-- Chat Widget -->
<div id="chat-widget" class="fixed bottom-4 right-4 z-50 flex flex-col items-end gap-3">
  <!-- Speech Bubble -->
  <div
    id="chat-bubble"
    class="hidden bg-white text-foreground text-sm font-medium px-4 py-3 rounded-xl shadow-lg border border-border max-w-56 animate-fade-in relative"
  >
    <button
      id="bubble-close"
      class="absolute -top-2 -right-2 size-5 bg-white border border-border rounded-full flex items-center justify-center text-muted-foreground hover:text-foreground transition-colors text-xs"
      aria-label="Dismiss"
    >
      &times;
    </button>
    Need help? Get a free quote!
  </div>

  <!-- Chat Panel -->
  <div
    id="chat-panel"
    class="hidden bg-white rounded-2xl shadow-2xl border border-border w-80 sm:w-96 overflow-hidden animate-fade-in"
  >
    <!-- Header -->
    <div class="bg-primary px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <img src={logo.src} alt="The Red Roofer" class="size-8 rounded-full bg-white object-contain" width="32" height="32" />
        <span class="text-primary-foreground font-semibold text-sm">The Red Roofer</span>
      </div>
      <button
        id="chat-close"
        class="text-primary-foreground/80 hover:text-primary-foreground transition-colors"
        aria-label="Close chat"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div class="p-4">
      <p class="text-muted-foreground text-sm mb-4">
        Hi! 👋 Need a free quote? Send us a message and we'll get back to you ASAP.
      </p>

      <form id="chat-form" class="space-y-3">
        <input
          type="text"
          name="name"
          placeholder="Your name"
          required
          class="w-full px-3 py-2 rounded-lg border border-input bg-background text-foreground text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
        />
        <input
          type="tel"
          name="phone"
          placeholder="Phone number"
          required
          class="w-full px-3 py-2 rounded-lg border border-input bg-background text-foreground text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
        />
        <textarea
          name="message"
          placeholder="How can we help?"
          rows="3"
          required
          class="w-full px-3 py-2 rounded-lg border border-input bg-background text-foreground text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring resize-none"
        ></textarea>
        <button
          type="submit"
          class="w-full bg-accent text-accent-foreground font-semibold text-sm py-2.5 rounded-lg hover:bg-accent/90 transition-colors"
        >
          Send Message
        </button>
      </form>

      <div id="chat-success" class="hidden text-center py-6">
        <p class="text-foreground font-semibold mb-1">Message sent!</p>
        <p class="text-muted-foreground text-sm">We'll get back to you shortly.</p>
      </div>
    </div>
  </div>

  <!-- Toggle Button -->
  <button
    id="chat-toggle"
    class="size-14 bg-accent text-accent-foreground rounded-full shadow-lg hover:bg-accent/90 transition-all flex items-center justify-center"
    aria-label="Open chat"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
  </button>
</div>

<!-- Get Free Quote Floating Button -->
<a
  id="floating-quote-btn"
  href="#"
  class="fixed bottom-20 right-4 z-40 hidden bg-accent text-accent-foreground font-semibold text-sm px-5 py-2.5 rounded-full shadow-lg hover:bg-accent/90 transition-all"
>
  Get Free Quote
</a>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.2s ease-out;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('chat-toggle') as HTMLButtonElement;
    const panel = document.getElementById('chat-panel') as HTMLDivElement;
    const bubble = document.getElementById('chat-bubble') as HTMLDivElement;
    const bubbleClose = document.getElementById('bubble-close') as HTMLButtonElement;
    const chatClose = document.getElementById('chat-close') as HTMLButtonElement;
    const form = document.getElementById('chat-form') as HTMLFormElement;
    const success = document.getElementById('chat-success') as HTMLDivElement;
    const floatingBtn = document.getElementById('floating-quote-btn') as HTMLAnchorElement;

    let panelOpen = false;
    let bubbleDismissed = false;

    // Show speech bubble after 3 seconds
    setTimeout(() => {
      if (!panelOpen && !bubbleDismissed) {
        bubble.classList.remove('hidden');
      }
    }, 3000);

    // Toggle chat panel
    toggle.addEventListener('click', () => {
      panelOpen = !panelOpen;
      if (panelOpen) {
        panel.classList.remove('hidden');
        bubble.classList.add('hidden');
      } else {
        panel.classList.add('hidden');
      }
    });

    // Close bubble
    bubbleClose.addEventListener('click', (e) => {
      e.stopPropagation();
      bubble.classList.add('hidden');
      bubbleDismissed = true;
    });

    // Close panel
    chatClose.addEventListener('click', () => {
      panel.classList.add('hidden');
      panelOpen = false;
    });

    // Open chat from floating button
    floatingBtn.addEventListener('click', (e) => {
      e.preventDefault();
      panelOpen = true;
      panel.classList.remove('hidden');
      bubble.classList.add('hidden');
    });

    // Show floating quote button on scroll
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        floatingBtn.classList.remove('hidden');
      } else {
        floatingBtn.classList.add('hidden');
      }
    });

    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = {
        name: formData.get('name'),
        phone: formData.get('phone'),
        message: formData.get('message'),
      };

      try {
        await fetch('https://services.leadconnectorhq.com/hooks/ks0cCYzWIf2tDiYJV3vw/webhook-trigger/9xqAoKHpJJ7LhBGm0oB9', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      } catch {
        // Submit silently even if webhook fails
      }

      form.classList.add('hidden');
      success.classList.remove('hidden');
    });
  });
</script>
