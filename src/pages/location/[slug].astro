---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { locations, getLocationBySlug } from '../../data/locations';
import { categories } from '../../data/categories';
import { getCriticalServices } from '../../data/services';

export function getStaticPaths() {
  return locations.map(loc => ({
    params: { slug: loc.slug },
  }));
}

const { slug } = Astro.params;
const location = getLocationBySlug(slug!);
if (!location) return Astro.redirect('/404');

const nearbyLocations = location.nearbyIds
  .map(id => locations.find(l => l.id === id))
  .filter(Boolean);

const criticalServices = getCriticalServices();

const locationSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "name": "The Red Roofer",
  "url": `https://theredroofer.com/location/${location.slug}`,
  "telephone": "+1-940-260-3197",
  "areaServed": { "@type": "City", "name": location.name, "addressRegion": "TX" }
};
---

<BaseLayout
  title={location.metaTitle}
  description={location.metaDescription}
  schemaJson={locationSchema}
>
  <!-- Hero Section -->
  <section class="hero-gradient relative overflow-hidden py-16 md:py-24">
    <!-- Decorative blur blob -->
    <div class="absolute top-10 right-10 w-64 sm:w-96 h-64 sm:h-96 bg-accent/20 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-background/60">
          <li><a href="/" class="hover:text-background transition-colors">Home</a></li>
          <li><span>/</span></li>
          <li><a href="/locations" class="hover:text-background transition-colors">Locations</a></li>
          <li><span>/</span></li>
          <li class="text-background font-medium">{location.name}</li>
        </ol>
      </nav>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-[family-name:var(--font-display)] font-extrabold text-background uppercase tracking-tight">
        Roofing Contractor in <span class="text-accent">{location.name}, TX</span>
      </h1>

      <p class="mt-6 text-lg md:text-xl text-background/80 max-w-3xl">
        <strong>The Red Roofer</strong> proudly serves <strong>{location.name}, Texas</strong>. {location.description}
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-start gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 bg-accent text-white font-extrabold uppercase tracking-tight px-8 py-4 rounded-lg hover:scale-[1.02] hover:shadow-lg transition-all"
        >
          Get Free Quote
        </a>
        <a
          href="tel:+19402603197"
          class="inline-flex items-center justify-center gap-2 border-2 border-background/30 text-background font-extrabold uppercase tracking-tight px-8 py-4 rounded-lg hover:bg-background/10 transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +1 940-260-3197
        </a>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="section-gradient py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

        <!-- Main Content Column -->
        <div class="lg:col-span-2 animate-on-scroll">
          <div class="bg-card rounded-xl p-6 sm:p-8 border-2 border-border">
            <h2 class="text-2xl md:text-3xl font-[family-name:var(--font-display)] font-extrabold uppercase tracking-tight text-foreground mb-6">
              Trusted Roofing Services in {location.name}, TX
            </h2>

            <p class="text-lg text-muted-foreground leading-relaxed mb-8">
              {location.content}
            </p>

            <!-- Neighborhoods & Landmarks description -->
            {(location.neighborhoods.length > 0 || location.landmarks.length > 0) && (
              <p class="text-muted-foreground mb-8">
                We serve homeowners near
                {location.neighborhoods.length > 0 && (
                  <span>
                    {' '}{location.neighborhoods.map((n, i) => (
                      <span class="inline-flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent inline"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        <strong>{n}</strong>{i < location.neighborhoods.length - 1 ? ', ' : ''}
                      </span>
                    ))}
                  </span>
                )}
                {location.landmarks.length > 0 && (
                  <span>
                    {location.neighborhoods.length > 0 ? ' and landmarks like ' : ' landmarks like '}
                    {location.landmarks.map((l, i) => (
                      <span class="inline-flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent inline"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                        <strong>{l}</strong>{i < location.landmarks.length - 1 ? ', ' : ''}
                      </span>
                    ))}
                  </span>
                )}.
              </p>
            )}

            <!-- Serving Neighborhoods & Areas -->
            {location.neighborhoods.length > 0 && (
              <div class="mb-8">
                <h3 class="text-xl font-[family-name:var(--font-display)] font-extrabold uppercase tracking-tight text-foreground mb-4">
                  Serving {location.name} Neighborhoods & Areas
                </h3>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  {location.neighborhoods.map(neighborhood => (
                    <li class="flex items-center gap-2 text-muted-foreground">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                      <span>{neighborhood}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- What We Offer -->
            <div>
              <h3 class="text-xl font-[family-name:var(--font-display)] font-extrabold uppercase tracking-tight text-foreground mb-4">
                What We Offer in {location.name}
              </h3>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {criticalServices.map(service => (
                  <li class="flex items-center gap-2 text-muted-foreground">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                    <span>{service.name}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6 animate-on-scroll">
          <!-- Dark Contact Card -->
          <div class="bg-foreground rounded-xl p-6 text-background">
            <h3 class="text-lg font-[family-name:var(--font-display)] font-extrabold uppercase tracking-tight mb-4">
              Call Us Today
            </h3>
            <p class="text-background/70 text-sm mb-4">
              Get a free, no-obligation quote for your roofing project in {location.name}.
            </p>
            <a
              href="tel:+19402603197"
              class="flex items-center gap-3 text-accent font-bold text-lg hover:text-accent/80 transition-colors mb-4"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +1 940-260-3197
            </a>
            <a
              href="/contact"
              class="block w-full text-center bg-accent text-white font-bold py-3 rounded-lg hover:bg-accent/90 transition-colors"
            >
              Get Free Quote
            </a>
          </div>

          <!-- Nearby Locations Card -->
          {nearbyLocations.length > 0 && (
            <div class="bg-card rounded-xl p-6 border-2 border-border">
              <h3 class="text-lg font-[family-name:var(--font-display)] font-extrabold uppercase tracking-tight text-foreground mb-4">
                Nearby Locations
              </h3>
              <ul class="space-y-2">
                {nearbyLocations.map(loc => loc && (
                  <li>
                    <a
                      href={`/location/${loc.slug}`}
                      class="flex items-center gap-2 text-muted-foreground hover:text-accent transition-colors"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                      <span>{loc.name}, TX</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid Section -->
  <section class="bg-secondary py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-display)] font-extrabold uppercase tracking-tight text-foreground">
          Our Service Categories
        </h2>
        <p class="mt-4 text-lg text-muted-foreground max-w-2xl mx-auto">
          Browse our full range of services available in {location.name}, TX.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-on-scroll">
        {categories.map(cat => (
          <a
            href={`/category/${cat.slug}`}
            class="bg-card p-5 sm:p-6 border-2 border-border rounded-xl hover-lift group block"
          >
            <h3 class="text-lg font-[family-name:var(--font-display)] font-extrabold uppercase tracking-tight text-foreground group-hover:text-accent transition-colors">
              {cat.name}
            </h3>
            <p class="mt-2 text-sm text-muted-foreground line-clamp-3">
              {cat.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-foreground py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-display)] font-extrabold uppercase tracking-tight text-background">
        Need a Roofer in <span class="text-accent">{location.name}</span>?
      </h2>
      <p class="mt-4 text-lg text-background/80">
        Get a free, no-obligation quote for roofing and home services in {location.name}, TX.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 bg-accent text-white font-extrabold uppercase tracking-tight px-8 py-4 rounded-lg hover:scale-[1.02] hover:shadow-lg transition-all"
        >
          Get A Free Quote
        </a>
        <a
          href="tel:+19402603197"
          class="inline-flex items-center justify-center gap-2 border-2 border-background/30 text-background font-extrabold uppercase tracking-tight px-8 py-4 rounded-lg hover:bg-background/10 transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +1 940-260-3197
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
