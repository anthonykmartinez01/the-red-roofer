<script>
  // Scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll, .animate-on-scroll-scale').forEach(el => observer.observe(el));

  // FAQ accordion
  document.querySelectorAll('[data-faq-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const index = (btn as HTMLElement).dataset.faqBtn;
      const content = document.querySelector(`[data-faq-content="${index}"]`);
      const icon = btn.querySelector('.faq-icon');
      const isOpen = content?.classList.contains('max-h-48');
      // Close all
      document.querySelectorAll('[data-faq-content]').forEach(c => {
        c.classList.remove('max-h-48');
        c.classList.add('max-h-0');
      });
      document.querySelectorAll('.faq-icon').forEach(i => {
        (i as HTMLElement).style.transform = '';
      });
      // Open clicked if was closed
      if (!isOpen) {
        content?.classList.remove('max-h-0');
        content?.classList.add('max-h-48');
        if (icon) (icon as HTMLElement).style.transform = 'rotate(180deg)';
      }
    });
  });

  // Form submission
  const form = document.getElementById('hero-quote-form');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = (form.querySelector('[name="name"]') as HTMLInputElement).value;
      const phone = (form.querySelector('[name="phone"]') as HTMLInputElement).value;
      const message = (form.querySelector('[name="message"]') as HTMLTextAreaElement).value;
      const mc = (form.querySelector('#marketing-consent') as HTMLInputElement).checked;
      const nmc = (form.querySelector('#non-marketing-consent') as HTMLInputElement).checked;
      if (!name || !phone || !message) { alert('Please fill in all required fields.'); return; }
      if (!mc || !nmc) { alert('Please accept both consent checkboxes.'); return; }
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      const webhookUrl = 'https://services.leadconnectorhq.com/hooks/ks0cCYzWIf2tDiYJV3vw/webhook-trigger/VwFSHBpsK7weSGkQxPIB';
      const formPayload = new URLSearchParams();
      formPayload.append('name', name);
      formPayload.append('phone', phone);
      formPayload.append('message', message);
      formPayload.append('source', 'Website - Homepage Quote Form');
      formPayload.append('timestamp', new Date().toISOString());
      try {
        await fetch(webhookUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, mode: 'no-cors', body: formPayload.toString() });
        alert('Thank you! Your quote request has been submitted. We\'ll be in touch soon.');
        form.reset();
      } catch (error) {
        alert('There was an error submitting your request. Please try again or call us directly.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'SEND';
      }
    });
  }
</script>
