---
import BaseLayout from '../components/layout/BaseLayout.astro';
import heroImg from '../assets/hero-shingles-bg.jpg';
import teamPhoto from '../assets/team-photo.png';
import workPreview from '../assets/gallery/work-preview.jpg';
import workPreview2 from '../assets/gallery/work-preview-2.jpg';
import workPreview3 from '../assets/gallery/work-preview-3.jpg';
import workPreview4 from '../assets/gallery/work-preview-4.jpg';
import workPreview5 from '../assets/gallery/work-preview-5.jpg';
import workPreview6 from '../assets/gallery/work-preview-6.jpg';
import { categories } from '../data/categories';
import { getCriticalServices } from '../data/services';
import { locations } from '../data/locations';

const criticalServices = getCriticalServices();

const roofingContractorSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "name": "The Red Roofer",
  "url": "https://theredroofer.com/",
  "logo": "https://theredroofer.com/favicon.png",
  "image": "https://theredroofer.com/og-image.png",
  "description": "The Red Roofer is a roofing contractor in Little Elm, TX serving the DFW metroplex with expert roof repairs, installations, handyman services, fencing, landscaping, and gutter cleaning.",
  "telephone": "+1-940-260-3197",
  "email": "theredroofer@gmail.com",
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    "opens": "07:00",
    "closes": "19:00"
  },
  "sameAs": ["https://maps.app.goo.gl/wjJBf8ppToSWBGyi7"]
};

const reviews = [
  { name: "Ryan M.", text: "The Red Roofer did a great job on our roof repair. They were quick to respond and the work was top-notch. Highly recommend!", date: "2024-11-15", rating: 5 },
  { name: "Sarah T.", text: "We had storm damage and they came out the same day. Very professional and honest about what needed to be done. Fair pricing too.", date: "2024-10-28", rating: 5 },
  { name: "Mike D.", text: "Great experience from start to finish. They replaced our entire roof and it looks amazing. Clean work, no mess left behind.", date: "2024-10-15", rating: 5 },
  { name: "Jennifer L.", text: "Called for a roof inspection before selling our house. They were thorough and gave us a detailed report. Helped us get top dollar!", date: "2024-09-22", rating: 5 },
  { name: "Carlos R.", text: "Best roofer in Little Elm! They fixed a leak that two other companies couldn't find. Honest, reliable, and skilled.", date: "2024-09-10", rating: 5 },
  { name: "Amanda W.", text: "They did our gutters and exterior painting. Both jobs were done perfectly. These guys really care about quality.", date: "2024-08-30", rating: 5 },
  { name: "David K.", text: "Had them install a new roof after hail damage. They handled the insurance paperwork and made the whole process stress-free.", date: "2024-08-15", rating: 5 },
  { name: "Lisa P.", text: "Very responsive and professional. They showed up when they said they would and finished ahead of schedule. Rare these days!", date: "2024-07-28", rating: 5 },
  { name: "James H.", text: "The Red Roofer replaced our old roof and it looks incredible. Fair price, great communication, and excellent craftsmanship.", date: "2024-07-12", rating: 5 },
  { name: "Patricia N.", text: "We've used them for multiple projects - roof repair, gutter cleaning, and handyman work. Always reliable and fairly priced.", date: "2024-06-25", rating: 5 },
  { name: "Robert S.", text: "They came out after a bad storm and tarped our roof the same day. Saved us from major water damage. Can't thank them enough.", date: "2024-06-10", rating: 5 },
  { name: "Maria G.", text: "Excellent communication throughout the entire roof replacement. They explained everything and there were no surprises on the bill.", date: "2024-05-28", rating: 5 },
  { name: "Thomas B.", text: "Quick, clean, and professional roof repair. They even cleaned up better than they found it. Would definitely use again.", date: "2024-05-15", rating: 5 },
  { name: "Nancy C.", text: "The team was super friendly and did amazing work on our roof. Neighbors have already asked for their number!", date: "2024-04-30", rating: 5 },
  { name: "Kevin F.", text: "Had a roof leak for months and other companies gave us the runaround. The Red Roofer found and fixed it in one visit.", date: "2024-04-18", rating: 5 },
  { name: "Susan A.", text: "From the free inspection to the final cleanup, everything was handled professionally. Our new roof looks fantastic.", date: "2024-03-25", rating: 5 },
  { name: "Brian E.", text: "Hands down the best roofing contractor in the DFW area. Quality work, fair prices, and they stand behind their work.", date: "2024-03-10", rating: 5 },
];

const faqs = [
  {
    question: "How much does a roof repair cost in Little Elm, TX?",
    answer: "Roof repair costs in Little Elm typically range from $300 to $1,500 depending on the extent of the damage. Minor repairs like fixing a few shingles are on the lower end, while more extensive repairs involving flashing or decking can be higher. We provide free inspections and honest estimates so you know exactly what to expect before any work begins."
  },
  {
    question: "Do you work with insurance companies for storm damage claims?",
    answer: "Yes! We work with all major insurance companies and have extensive experience with storm damage claims in the DFW area. We document all damage with photos, provide detailed estimates in the format insurance adjusters need, and can meet with your adjuster on-site to make sure nothing is missed. We make the claims process as stress-free as possible."
  },
  {
    question: "How long does a roof replacement take?",
    answer: "Most residential roof replacements in Little Elm take 1-3 days depending on the size of your home and the complexity of the roof. We work efficiently to minimize disruption to your daily life. Weather can sometimes cause delays, but we'll communicate with you every step of the way and never cut corners to speed things up."
  },
  {
    question: "What areas do you serve?",
    answer: "We're based in Little Elm, TX and serve the entire DFW metroplex including Frisco, The Colony, Prosper, Celina, McKinney, Allen, Plano, Denton, Lewisville, and surrounding communities. If you're in the North Texas area, we can help!"
  }
];

const galleryImages = [
  { src: workPreview.src, alt: "Roofing work preview 1" },
  { src: workPreview2.src, alt: "Roofing work preview 2" },
  { src: workPreview3.src, alt: "Roofing work preview 3" },
  { src: workPreview4.src, alt: "Roofing work preview 4" },
  { src: workPreview5.src, alt: "Roofing work preview 5" },
  { src: workPreview6.src, alt: "Roofing work preview 6" },
];

const processSteps = [
  { number: "1", title: "Contact Us", description: "Give us a call or fill out a form" },
  { number: "2", title: "Get Your Quote", description: "We'll inspect and provide a free estimate" },
  { number: "3", title: "Schedule Work", description: "Pick a time that works for you" },
  { number: "4", title: "Job Complete", description: "We finish the job right, guaranteed" },
];

const displayLocations = locations.slice(0, 10);
---

<BaseLayout
  title="Roofing Contractor Little Elm, TX | The Red Roofer"
  description="The Red Roofer is a roofing contractor in Little Elm, TX. We offer roof repair, roof installation, gutter cleaning, handyman services, and more. Call today!"
  schemaJson={roofingContractorSchema}
>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={heroImg.src}
        alt="Professional roofing shingles background"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[hsl(149,51%,20%)]/95 via-[hsl(149,51%,20%)]/85 to-[hsl(149,51%,20%)]/70"></div>
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left Column -->
        <div class="text-white space-y-6 sm:space-y-8">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-display font-extrabold tracking-tight leading-[1.1]">
            Little Elm's Trusted<br />
            <span class="gradient-text">Roofing Contractor</span>
          </h1>
          <p class="text-lg sm:text-xl text-white/90 max-w-xl leading-relaxed">
            From roof repairs to full installations, The Red Roofer delivers honest work and quality craftsmanship to homeowners across Little Elm, TX and the DFW metroplex.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/contact"
              class="inline-flex items-center justify-center gap-2 bg-white text-[hsl(149,51%,20%)] font-extrabold uppercase tracking-tight px-8 py-4 hover:scale-[1.02] hover:shadow-lg transition-all"
            >
              Get A Free Quote
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Right Column - Quote Form -->
        <div class="bg-white rounded-2xl shadow-2xl p-6 sm:p-8 max-w-md mx-auto lg:mx-0 lg:ml-auto w-full">
          <h2 class="text-2xl font-display font-bold text-[hsl(149,51%,20%)] mb-6 text-center">Get A Free Quote</h2>
          <form id="hero-form" class="space-y-4">
            <div>
              <input
                type="text"
                name="name"
                placeholder="Your Name"
                required
                class="w-full px-4 py-3 border border-[hsl(89,20%,88%)] rounded-lg text-[hsl(149,51%,20%)] placeholder:text-[hsl(92,30%,35%)]/50 focus:outline-none focus:ring-2 focus:ring-[hsl(14,100%,57%)] focus:border-transparent transition-all"
              />
            </div>
            <div>
              <input
                type="tel"
                name="phone"
                placeholder="Phone Number"
                required
                class="w-full px-4 py-3 border border-[hsl(89,20%,88%)] rounded-lg text-[hsl(149,51%,20%)] placeholder:text-[hsl(92,30%,35%)]/50 focus:outline-none focus:ring-2 focus:ring-[hsl(14,100%,57%)] focus:border-transparent transition-all"
              />
            </div>
            <div>
              <textarea
                name="message"
                placeholder="Tell us about your project"
                rows="3"
                class="w-full px-4 py-3 border border-[hsl(89,20%,88%)] rounded-lg text-[hsl(149,51%,20%)] placeholder:text-[hsl(92,30%,35%)]/50 focus:outline-none focus:ring-2 focus:ring-[hsl(14,100%,57%)] focus:border-transparent transition-all resize-none"
              ></textarea>
            </div>
            <div class="space-y-3">
              <label class="flex items-start gap-2 text-sm text-[hsl(92,30%,35%)]">
                <input type="checkbox" name="consent_contact" required class="mt-1 rounded border-[hsl(89,20%,88%)] text-[hsl(14,100%,57%)] focus:ring-[hsl(14,100%,57%)]" />
                <span>I consent to being contacted by The Red Roofer regarding my inquiry.</span>
              </label>
              <label class="flex items-start gap-2 text-sm text-[hsl(92,30%,35%)]">
                <input type="checkbox" name="consent_terms" required class="mt-1 rounded border-[hsl(89,20%,88%)] text-[hsl(14,100%,57%)] focus:ring-[hsl(14,100%,57%)]" />
                <span>I agree to the terms and conditions and privacy policy.</span>
              </label>
            </div>
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center gap-2 bg-[hsl(14,100%,57%)] text-white font-extrabold uppercase tracking-tight px-6 py-3 hover:scale-[1.02] hover:shadow-lg transition-all"
            >
              Submit Request
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </form>
          <p id="hero-form-status" class="mt-4 text-center text-sm hidden"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-foreground text-background py-8 sm:py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-3 gap-4 sm:gap-8 text-center">
        <div>
          <div class="text-2xl sm:text-3xl lg:text-4xl font-display font-extrabold">100%</div>
          <div class="text-sm sm:text-base text-background/70 mt-1">Local</div>
        </div>
        <div>
          <div class="text-2xl sm:text-3xl lg:text-4xl font-display font-extrabold">Family</div>
          <div class="text-sm sm:text-base text-background/70 mt-1">Business</div>
        </div>
        <div>
          <div class="text-2xl sm:text-3xl lg:text-4xl font-display font-extrabold">Quality</div>
          <div class="text-sm sm:text-base text-background/70 mt-1">Work</div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center animate-on-scroll">
        <div class="space-y-6">
          <span class="text-[hsl(14,100%,57%)] font-bold text-sm uppercase tracking-wider">About Us</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold text-[hsl(149,51%,20%)] tracking-tight">
            Your Trusted Local<br />Roofing Partner
          </h2>
          <p class="text-lg text-[hsl(92,30%,35%)] leading-relaxed">
            The Red Roofer is a family-owned roofing and home services company proudly serving Little Elm, TX and the surrounding DFW communities. We built our business on honest work, fair pricing, and treating every home like it's our own. From roof repairs and installations to gutter cleaning and handyman services, we're the team your neighbors trust.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 bg-[hsl(14,100%,57%)] text-white font-extrabold uppercase tracking-tight px-6 py-3 hover:scale-[1.02] hover:shadow-lg transition-all"
          >
            Get In Touch
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="relative">
          <img
            src={teamPhoto.src}
            alt="The Red Roofer team"
            class="rounded-2xl shadow-xl w-full h-auto"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Critical Services Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-[hsl(89,30%,95%)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 animate-on-scroll">
        <span class="text-[hsl(14,100%,57%)] font-bold text-sm uppercase tracking-wider">What We Do</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold text-[hsl(149,51%,20%)] tracking-tight mt-3">
          Our Core Services
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
        {criticalServices.map((service) => (
          <a
            href={`/service/${service.slug}`}
            class="group bg-white rounded-xl border border-[hsl(89,20%,88%)] p-6 sm:p-8 hover-lift animate-on-scroll"
          >
            <h3 class="text-xl font-display font-bold text-[hsl(149,51%,20%)] mb-3 group-hover:text-[hsl(14,100%,57%)] transition-colors">
              {service.name}
            </h3>
            <p class="text-[hsl(92,30%,35%)] text-sm leading-relaxed mb-4">
              {service.description}
            </p>
            <span class="inline-flex items-center gap-1 text-[hsl(14,100%,57%)] font-bold text-sm uppercase tracking-wide">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 animate-on-scroll">
        <span class="text-[hsl(14,100%,57%)] font-bold text-sm uppercase tracking-wider">How It Works</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold text-[hsl(149,51%,20%)] tracking-tight mt-3">
          Simple 4-Step Process
        </h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
        {processSteps.map((step) => (
          <div class="text-center animate-on-scroll">
            <div class="w-16 h-16 sm:w-20 sm:h-20 mx-auto rounded-full bg-[hsl(14,100%,57%)] text-white flex items-center justify-center text-2xl sm:text-3xl font-display font-extrabold mb-4">
              {step.number}
            </div>
            <h3 class="text-lg sm:text-xl font-display font-bold text-[hsl(149,51%,20%)] mb-2">{step.title}</h3>
            <p class="text-sm text-[hsl(92,30%,35%)]">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Marquee Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-[hsl(89,30%,95%)] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 sm:mb-12">
      <div class="text-center animate-on-scroll">
        <span class="text-[hsl(14,100%,57%)] font-bold text-sm uppercase tracking-wider">Our Work</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold text-[hsl(149,51%,20%)] tracking-tight mt-3">
          Recent Projects
        </h2>
      </div>
    </div>
    <div class="overflow-hidden">
      <div class="marquee">
        {[...galleryImages, ...galleryImages].map((img, i) => (
          <div class="flex-shrink-0 w-72 sm:w-80 lg:w-96 mx-3">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-48 sm:h-56 lg:h-64 object-cover rounded-xl"
              loading="lazy"
              width="384"
              height="256"
            />
          </div>
        ))}
      </div>
    </div>
    <div class="text-center mt-8 sm:mt-12">
      <a
        href="/gallery"
        class="inline-flex items-center justify-center gap-2 border-2 border-[hsl(89,20%,88%)] bg-transparent text-[hsl(149,51%,20%)] font-extrabold uppercase tracking-tight px-6 py-3 hover:scale-[1.02] transition-all"
      >
        See All Photos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Reviews Marquee Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-background overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 sm:mb-12">
      <div class="text-center animate-on-scroll">
        <span class="text-[hsl(14,100%,57%)] font-bold text-sm uppercase tracking-wider">Reviews</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold text-[hsl(149,51%,20%)] tracking-tight mt-3">
          What Our Customers Say
        </h2>
      </div>
    </div>
    <div class="overflow-hidden">
      <div class="marquee-slow">
        {[...reviews, ...reviews].map((review, i) => (
          <div class="flex-shrink-0 w-80 sm:w-96 mx-3">
            <div class="bg-white rounded-xl border border-[hsl(89,20%,88%)] p-6 h-full flex flex-col">
              <!-- Stars -->
              <div class="flex items-center gap-0.5 mb-3">
                {Array.from({ length: review.rating }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" class="text-yellow-400"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
              <!-- Quote -->
              <p class="text-[hsl(92,30%,35%)] text-sm leading-relaxed flex-1 mb-4">"{review.text}"</p>
              <!-- Author -->
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <!-- Avatar with initials -->
                  <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-[hsl(149,51%,20%)] text-white flex items-center justify-center text-xs sm:text-sm font-bold">
                    {review.name.split(' ').map(n => n[0]).join('')}
                  </div>
                  <div>
                    <div class="font-semibold text-sm text-[hsl(149,51%,20%)]">{review.name}</div>
                    <div class="text-xs text-[hsl(92,30%,35%)]/60">{new Date(review.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</div>
                  </div>
                </div>
                <!-- Google Icon -->
                <svg class="w-5 h-5 sm:w-6 sm:h-6 lg:w-8 lg:h-8 flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="text-center mt-8 sm:mt-12">
      <a
        href="https://maps.app.goo.gl/wjJBf8ppToSWBGyi7"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 border-2 border-[hsl(89,20%,88%)] bg-transparent text-[hsl(149,51%,20%)] font-extrabold uppercase tracking-tight px-6 py-3 hover:scale-[1.02] transition-all"
      >
        Leave Us a Google Review
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- FAQ Section -->
