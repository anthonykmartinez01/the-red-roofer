<script>
  // Hero form submission
  const heroForm = document.getElementById('hero-form') as HTMLFormElement;
  const heroFormStatus = document.getElementById('hero-form-status');

  if (heroForm && heroFormStatus) {
    heroForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(heroForm);
      const data = {
        name: formData.get('name'),
        phone: formData.get('phone'),
        message: formData.get('message'),
        source: 'homepage-hero-form',
      };

      try {
        const response = await fetch(
          'https://services.leadconnectorhq.com/hooks/ks0cCYzWIf2tDiYJV3vw/webhook-trigger/VwFSHBpsK7weSGkQxPIB',
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          }
        );

        if (response.ok) {
          heroFormStatus.textContent = 'Thank you! We\'ll be in touch soon.';
          heroFormStatus.className = 'mt-4 text-center text-sm text-green-600';
          heroFormStatus.classList.remove('hidden');
          heroForm.reset();
        } else {
          throw new Error('Failed to submit');
        }
      } catch (err) {
        heroFormStatus.textContent = 'Something went wrong. Please call us at (940) 260-3197.';
        heroFormStatus.className = 'mt-4 text-center text-sm text-red-600';
        heroFormStatus.classList.remove('hidden');
      }
    });
  }

  // FAQ accordion
  document.querySelectorAll('[data-faq-toggle]').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const item = toggle.closest('[data-faq-item]');
      if (!item) return;

      const content = item.querySelector('[data-faq-content]');
      const chevron = toggle.querySelector('[data-faq-chevron]');
      const isOpen = !content?.classList.contains('hidden');

      // Close all other items
      document.querySelectorAll('[data-faq-item]').forEach((otherItem) => {
        if (otherItem !== item) {
          otherItem.querySelector('[data-faq-content]')?.classList.add('hidden');
          otherItem.querySelector('[data-faq-toggle]')?.setAttribute('aria-expanded', 'false');
          otherItem.querySelector('[data-faq-chevron]')?.classList.remove('rotate-180');
        }
      });

      // Toggle current item
      if (isOpen) {
        content?.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        chevron?.classList.remove('rotate-180');
      } else {
        content?.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        chevron?.classList.add('rotate-180');
      }
    });
  });
</script>
