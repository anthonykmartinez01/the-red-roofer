---
import BaseLayout from '../components/layout/BaseLayout.astro';
import heroImg from '../assets/hero-shingles-bg.jpg';
import teamPhoto from '../assets/team-photo.png';
import workPreview from '../assets/gallery/work-preview.jpg';
import workPreview2 from '../assets/gallery/work-preview-2.jpg';
import workPreview3 from '../assets/gallery/work-preview-3.jpg';
import workPreview4 from '../assets/gallery/work-preview-4.jpg';
import workPreview5 from '../assets/gallery/work-preview-5.jpg';
import workPreview6 from '../assets/gallery/work-preview-6.jpg';
import { getCriticalServices } from '../data/services';
import { locations } from '../data/locations';

const criticalServices = getCriticalServices();

const roofingContractorSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "name": "The Red Roofer",
  "url": "https://theredroofer.com/",
  "logo": "https://theredroofer.com/favicon.png",
  "image": "https://theredroofer.com/og-image.png",
  "description": "The Red Roofer is a roofing contractor in Little Elm, TX serving the DFW metroplex with expert roof repairs, installations, handyman services, fencing, landscaping, and gutter cleaning.",
  "telephone": "+1-940-260-3197",
  "email": "theredroofer@gmail.com",
  "areaServed": locations.map(l => `${l.name}, TX`),
  "makesOffer": [
    ...getCriticalServices().map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.name, "serviceType": s.name }
    })),
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Handyman Services", "serviceType": "Handyman Services" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fencing", "serviceType": "Fencing" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Landscaping", "serviceType": "Landscaping" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Chimney Services", "serviceType": "Chimney Services" } },
  ],
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    "opens": "07:00",
    "closes": "19:00"
  },
  "sameAs": ["https://maps.app.goo.gl/wjJBf8ppToSWBGyi7"]
};

const stats = [
  { label: "100% Local", sublabel: "Little Elm, TX Based" },
  { label: "Family Business", sublabel: "Trusted Service" },
  { label: "Quality Work", sublabel: "Guaranteed Results" }
];

const processSteps = [
  { step: "1", title: "Contact Us", description: "Reach out for a free consultation and estimate" },
  { step: "2", title: "Get Your Quote", description: "We'll assess your needs and provide a fair price" },
  { step: "3", title: "Schedule Work", description: "Pick a time that works best for you" },
  { step: "4", title: "Job Complete", description: "We finish the job to your satisfaction" }
];

const reviews = [
  { name: "Mary Ellen Doster", text: "Contacted William at The Red Roofer to get an estimate for minor storm damage and he was prompt, polite, and able to complete the repair within 24 hours. Will definitely be keeping his contact information and using him in the future.", rating: 5, date: "4 days ago" },
  { name: "Ambrea Ferlet", text: "Hands down best roofing and handyman service professional. Highly recommend! Offers a variety of services, and is amazing at everything!", rating: 5, date: "1 week ago" },
  { name: "Brandon Shea", text: "Quick and efficient would recommend it to anyone.", rating: 5, date: "1 week ago" },
  { name: "Jennifer Roybal", text: "I had an exceptional experience with The Red Roofer. From start to finish, they were professional, on time, and incredibly knowledgeable. They explained everything clearly and made sure I understood the repairs. Their team was friendly, thorough, and made it obvious that they truly care about doing the job right.", rating: 5, date: "2 weeks ago" },
  { name: "Traveler 123", text: "We have used William for several handy man items. He is responsive and reasonable. Highly recommend.", rating: 5, date: "2 weeks ago" },
  { name: "Molly Cunningham", text: "Professional, knowledgeable, reliable and produced great work! Highly recommend using The Red Roofer if you want the job done right and with integrity.", rating: 5, date: "1 month ago" },
  { name: "Aaron Turner", text: "William does a great job! The crews he used to complete the jobs we hired him for were all top-notch, and everything we asked him to do was reasonably priced. He communicates well and was always quick to respond.", rating: 5, date: "1 month ago" },
  { name: "Jose Mendez", text: "William, the 'Red Roofer,' did an outstanding job helping me patch a hole in my roofline. From start to finish, he was professional, patient, and incredibly transparent about the process. That level of openness and confidence in his craft is rare.", rating: 5, date: "1 month ago" },
  { name: "Victoria Archie", text: "William does great work gets the job done quick and he is responsive. He installed lights and ceiling fans, was a tremendous help.", rating: 5, date: "2 months ago" },
  { name: "Christian Lopez", text: "William was amazing! We got his quote and the next day he completed the job. I recommend him for all of your handyman needs!", rating: 5, date: "3 months ago" },
  { name: "Caroline Korshak", text: "So reassuring. Great advice and quick tidy work. I'm glad to have Red Roofer available to keep tabs on my roof!", rating: 5, date: "3 months ago" },
  { name: "Jason G", text: "Very friendly, stayed in contact with me throughout the job, and got it done quickly. Did great work. Definitely will use again in future home repairs. Would highly recommend.", rating: 5, date: "3 months ago" },
  { name: "Kathy Silva", text: "William is a great communicator. My job was done quickly, without delays — would recommend and will be using the red roofer again!", rating: 5, date: "3 months ago" },
  { name: "Megan Bennett", text: "Red Roofer LLC is truly top-notch! As a property manager, I need vendors who show up on time and get the job done right — and Red Roofer LLC delivered exactly that. Punctual, professional.", rating: 5, date: "3 months ago" },
  { name: "Mary Morris", text: "William did some roof repairs for us. He did a great job. We had him come to our new house and put up fans and blinds and lighting. He did a wonderful job in all aspects. Would definitely recommend him for roofing and handyman duties.", rating: 5, date: "4 months ago" },
  { name: "Heidi Wheeler", text: "I had a great experience with Red Roofer. He's prompt and friendly on top of knowing what he's doing. If you need help with any task, big or small, he can take care of you.", rating: 5, date: "4 months ago" },
  { name: "Keith Forbes", text: "William was great, did the estimate and job same day for a very fair price. Would definitely recommend.", rating: 5, date: "4 months ago" },
];

const faqs = [
  { question: "Do you offer free estimates?", answer: "Yes! We provide free, no-obligation estimates for all our services. Contact us to schedule yours today." },
  { question: "What areas do you serve?", answer: "We proudly serve Little Elm, TX and the DFW metroplex including Aubrey, Frisco, The Colony, Denton, Prosper, Celina, McKinney, Plano, Lewisville, and surrounding cities." },
  { question: "Are you licensed and insured?", answer: "Yes, we are fully licensed and insured, providing you complete peace of mind for every project." },
  { question: "What roofing services do you offer?", answer: "We offer roof repair, roof installation, roof inspections, gutter cleaning, gutter repairs, storm damage repair, and chimney services." }
];

const galleryItems = [
  { src: workPreview.src, alt: "Roofing project Little Elm TX" },
  { src: workPreview2.src, alt: "Roof repair Little Elm TX" },
  { src: workPreview3.src, alt: "Handyman services Little Elm" },
  { src: workPreview6.src, alt: "Home repair services Little Elm TX" },
  { src: workPreview4.src, alt: "Gutter cleaning Little Elm TX" },
  { src: workPreview5.src, alt: "Fence installation Little Elm" },
];

const duplicatedReviews = [...reviews, ...reviews];
const displayLocations = locations.slice(0, 10);
---

<BaseLayout
  title="Roofing Contractor Little Elm, TX | The Red Roofer"
  description="The Red Roofer is a roofing contractor in Little Elm, TX. We offer roof repair, roof installation, gutter cleaning, handyman services, and more. Call today!"
  schemaJson={roofingContractorSchema}
>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center relative overflow-hidden pt-16 lg:pt-0">
    <div class="absolute inset-0 bg-gradient-to-br from-primary to-primary/80"></div>
    <img src={heroImg.src} alt="" role="presentation" fetchpriority="high" decoding="sync" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/55 lg:bg-black/50"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-8 sm:py-12 lg:py-20 w-full">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div class="text-center lg:text-left">
          <h1 class="font-[family-name:var(--font-display)] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-primary-foreground mb-3 sm:mb-4 leading-[1.1] uppercase">
            Little Elm's Trusted
            <br />
            <span class="gradient-text">Roofing Contractor</span>
          </h1>
          <p class="text-sm sm:text-base lg:text-lg text-primary-foreground/80 mb-4 sm:mb-6 max-w-lg mx-auto lg:mx-0 leading-relaxed">
            The Red Roofer is your trusted <strong>roofing contractor in Little Elm, TX</strong>. We provide expert roof repairs, installations, gutter cleaning, handyman services, and more across the DFW metroplex. Honest work, fair prices.
          </p>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-accent text-accent-foreground rounded-md font-bold uppercase tracking-wide hover:bg-accent/90 hover:scale-[1.02] hover:shadow-xl active:scale-[0.98] transition-all sm:hidden h-12 px-8 text-base">
            Get A Free Quote <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="hidden sm:inline-flex items-center justify-center gap-2 bg-accent text-accent-foreground rounded-md font-bold uppercase tracking-wide hover:bg-accent/90 hover:scale-[1.02] hover:shadow-xl active:scale-[0.98] transition-all h-14 px-10 text-lg">
            Get A Free Quote <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="bg-card/95 p-4 sm:p-5 md:p-6 shadow-2xl rounded-xl lg:rounded-2xl max-w-md">
          <h2 class="font-[family-name:var(--font-display)] text-lg sm:text-xl font-extrabold text-foreground mb-3 sm:mb-4 text-center uppercase tracking-tight">Get A Free Quote</h2>
          <form id="hero-quote-form" class="space-y-2.5 sm:space-y-3">
            <div>
              <label for="hero-name" class="block text-xs font-bold text-foreground mb-1">Full Name *</label>
              <input type="text" id="hero-name" name="name" placeholder="John Smith" required class="w-full px-3 py-2.5 border-2 border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-accent transition-colors text-sm" />
            </div>
            <div>
              <label for="hero-phone" class="block text-xs font-bold text-foreground mb-1">Phone *</label>
              <input type="tel" id="hero-phone" name="phone" placeholder="(808) 555-1234" required class="w-full px-3 py-2.5 border-2 border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-accent transition-colors text-sm" />
            </div>
            <div>
              <label for="hero-message" class="block text-xs font-bold text-foreground mb-1">Short message about your needs *</label>
              <textarea id="hero-message" name="message" placeholder="Your message goes straight to my phone" rows="2" required class="w-full px-3 py-2.5 border-2 border-border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-accent resize-none transition-colors text-sm"></textarea>
            </div>
            <div class="flex items-start gap-2">
              <input type="checkbox" id="marketing-consent" class="mt-0.5 w-3.5 h-3.5" />
              <label for="marketing-consent" class="text-[10px] sm:text-xs text-muted-foreground leading-tight">
                I consent to receive marketing text messages from The Red Roofer at the phone number provided. Frequency may vary. Message & data rates may apply. Text HELP for assistance, reply STOP to opt out.
              </label>
            </div>
            <div class="flex items-start gap-2">
              <input type="checkbox" id="non-marketing-consent" class="mt-0.5 w-3.5 h-3.5" />
              <label for="non-marketing-consent" class="text-[10px] sm:text-xs text-muted-foreground leading-tight">
                I consent to receive non-marketing text messages from The Red Roofer about my order updates, appointment reminders, etc. Message & data rates may apply.
              </label>
            </div>
            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 bg-accent text-accent-foreground rounded-md font-extrabold uppercase tracking-tight hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] transition-all h-11 px-5 py-2 text-sm">
              SEND
            </button>
            <p class="text-[10px] text-center text-muted-foreground">
              By submitting, you agree to our <a href="/terms-and-conditions" class="text-accent hover:underline">Terms & Conditions</a> and <a href="/privacy-policy" class="text-accent hover:underline">Privacy Policy</a>.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-6 sm:py-8 md:py-10 bg-foreground text-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-3 gap-4 sm:gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="font-[family-name:var(--font-display)] text-sm sm:text-lg md:text-2xl font-extrabold text-accent uppercase tracking-tight">{stat.label}</p>
            <p class="text-background/60 text-[10px] sm:text-xs md:text-sm uppercase tracking-wide">{stat.sublabel}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-12 sm:py-16 lg:py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 animate-on-scroll">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div class="order-2 lg:order-1 text-center lg:text-left">
          <span class="text-accent font-bold uppercase tracking-widest text-xs sm:text-sm">About Us</span>
          <h2 class="font-[family-name:var(--font-display)] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-foreground mt-2 mb-4 sm:mb-6 uppercase tracking-tight">
            Your <span class="gradient-text">Trusted</span> Roofing Contractor in Little Elm
          </h2>
          <p class="text-muted-foreground text-sm sm:text-base lg:text-lg leading-relaxed">
            The Red Roofer is a family-owned <strong>roofing contractor</strong> proudly serving <strong>Little Elm, TX</strong> and the DFW metroplex. We bring years of experience, quality craftsmanship, and honest service to every project. From storm damage repairs near Paloma Creek to full roof replacements in Union Park — we treat your home like our own.
          </p>
        </div>
        <div class="flex justify-center order-1 lg:order-2">
          <img src={teamPhoto.src} alt="The Red Roofer team serving Little Elm TX" loading="lazy" decoding="async" class="w-full max-w-xs sm:max-w-sm lg:max-w-md object-cover shadow-xl border-2 border-border" />
        </div>
      </div>
    </div>
  </section>

  <!-- Critical Roofing Services -->
  <section class="py-12 sm:py-16 lg:py-24 bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 animate-on-scroll">
      <div class="text-center mb-8 sm:mb-12 lg:mb-16">
        <span class="text-accent font-bold uppercase tracking-widest text-xs sm:text-sm">Primary Services</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-foreground mt-2 uppercase tracking-tight">
          Roofing Services in Little Elm
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
        {criticalServices.map((service, index) => (
          <a href={`/service/${service.slug}`} class="bg-card p-5 sm:p-6 border-2 border-border hover-lift group animate-on-scroll" style={`transition-delay: ${index * 60}ms`}>
            <h3 class="font-[family-name:var(--font-display)] font-extrabold text-sm sm:text-base text-foreground mb-2 group-hover:text-accent transition-colors uppercase tracking-tight">{service.name}</h3>
            <p class="text-muted-foreground text-xs sm:text-sm leading-relaxed line-clamp-3">{service.description}</p>
            <span class="inline-flex items-center gap-1 text-accent text-xs font-bold mt-3 uppercase tracking-wide">
              Learn More <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-12 sm:py-16 lg:py-24 bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 animate-on-scroll">
      <div class="text-center mb-8 sm:mb-12 lg:mb-16">
        <span class="text-accent font-bold uppercase tracking-widest text-xs sm:text-sm">How It Works</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-foreground mt-2 uppercase tracking-tight">Our Process</h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 lg:gap-6">
        {processSteps.map((item, index) => (
          <div class="text-center p-4 sm:p-5 lg:p-6 bg-card border-2 border-border hover-lift animate-on-scroll" style={`transition-delay: ${index * 60}ms`}>
            <div class="w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14 bg-accent flex items-center justify-center mx-auto mb-3 sm:mb-4">
              <span class="font-[family-name:var(--font-display)] text-lg sm:text-xl lg:text-2xl font-extrabold text-accent-foreground">{item.step}</span>
            </div>
            <h3 class="font-[family-name:var(--font-display)] font-extrabold text-sm sm:text-base lg:text-lg text-foreground mb-1 sm:mb-2 uppercase">{item.title}</h3>
            <p class="text-muted-foreground text-xs sm:text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-12 sm:py-16 lg:py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-12 lg:mb-16">
        <span class="text-accent font-bold uppercase tracking-widest text-xs sm:text-sm">See Why Our Customers Love Us</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-foreground mt-2 uppercase tracking-tight">
          See Our <span class="gradient-text">Work</span>
        </h2>
      </div>
      <div class="overflow-hidden">
        <div class="marquee">
          {[...galleryItems, ...galleryItems].map((img) => (
            <div class="flex-shrink-0 w-[50%] sm:w-[33.333%] lg:w-[25%] px-1 sm:px-2">
              <div class="aspect-square bg-muted img-skeleton overflow-hidden group cursor-pointer transition-shadow duration-200 hover:shadow-lg">
                <img src={img.src} alt={img.alt} loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="text-center mt-8 sm:mt-10 lg:mt-12">
        <a href="/gallery" class="inline-flex items-center justify-center gap-2 bg-accent text-accent-foreground rounded-md font-bold uppercase tracking-wide hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] transition-all h-12 px-8 text-base">
          See All Photos
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="py-12 sm:py-16 lg:py-24 bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-12 lg:mb-16">
        <span class="text-accent font-bold uppercase tracking-widest text-xs sm:text-sm">Discover What Our Customers Have To Say</span>
        <h2 class="font-[family-name:var(--font-display)] text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-foreground mt-2 uppercase tracking-tight">
          <span class="gradient-text">5-Star</span> Reviews
        </h2>
        <p class="text-muted-foreground mt-3 sm:mt-4 text-sm sm:text-base">5.0 rating from 33 Google reviews</p>
      </div>
      <div class="overflow-hidden">
        <div class="marquee-slow">
          {duplicatedReviews.map((review) => (
            <div class="flex-shrink-0 w-[85%] sm:w-[50%] lg:w-[33.333%] px-2 sm:px-3">
              <div class="bg-card p-4 sm:p-5 lg:p-8 border-2 border-border transition-all duration-300 hover:border-accent hover:shadow-xl h-full">
                <div class="flex items-center gap-1 sm:gap-2 mb-3 sm:mb-4">
                  <span class="text-accent font-bold text-sm sm:text-base lg:text-lg">{review.rating}</span>
                  <div class="flex gap-0.5 sm:gap-1">
                    {Array.from({ length: review.rating }).map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 sm:w-4 sm:h-4 lg:w-5 lg:h-5 fill-accent text-accent" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    ))}
                  </div>
                </div>
                <p class="text-muted-foreground mb-4 sm:mb-6 text-sm sm:text-base lg:text-lg leading-relaxed line-clamp-4">"{review.text}"</p>
                <div class="mt-auto flex items-center justify-between">
                  <div class="flex items-center gap-2 sm:gap-3">
                    <div class="w-9 h-9 sm:w-10 sm:h-10 lg:w-12 lg:h-12 rounded-full border-2 border-border bg-accent text-accent-foreground flex items-center justify-center font-bold text-xs sm:text-sm flex-shrink-0">
                      {review.name.split(' ').map(n => n[0]).join('')}
                    </div>
                    <div>
                      <p class="font-[family-name:var(--font-display)] font-extrabold text-foreground uppercase tracking-wide text-xs sm:text-sm lg:text-base">{review.name}</p>
                      <p class="text-[10px] sm:text-xs lg:text-sm text-muted-foreground">{review.date}</p>
                    </div>
                  </div>
                  <svg class="w-5 h-5 sm:w-6 sm:h-6 lg:w-8 lg:h-8 flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
