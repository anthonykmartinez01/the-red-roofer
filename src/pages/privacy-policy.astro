---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy | The Red Roofer"
  description="Privacy policy for The Red Roofer website."
  noIndex={true}
>
  <section class="bg-background py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="font-display font-extrabold text-3xl md:text-4xl text-foreground mb-4">Privacy Policy</h1>
      <p class="text-muted-foreground mb-10">Last updated: January 1, 2025</p>

      <div class="space-y-10 text-foreground leading-relaxed">
        <div>
          <h2 class="font-display font-extrabold text-xl md:text-2xl text-foreground mb-3">Information We Collect</h2>
          <p class="text-muted-foreground">
            When you submit a form on our website, we may collect personal information including your name, phone number, email address, and the content of your message. We only collect information that you voluntarily provide to us.
          </p>
        </div>

        <div>
          <h2 class="font-display font-extrabold text-xl md:text-2xl text-foreground mb-3">How We Use Your Information</h2>
          <p class="text-muted-foreground mb-3">We use the information we collect to:</p>
          <ul class="list-disc list-inside text-muted-foreground space-y-1">
            <li>Respond to your inquiries and requests</li>
            <li>Provide estimates for our services</li>
            <li>Send appointment reminders</li>
            <li>Improve our services and customer experience</li>
          </ul>
        </div>

        <div>
          <h2 class="font-display font-extrabold text-xl md:text-2xl text-foreground mb-3">Information Sharing</h2>
          <p class="text-muted-foreground">
            We do not sell, trade, or rent your personal information to third parties. We may share your information with trusted service providers who assist us in operating our business, provided they agree to keep your information confidential.
          </p>
        </div>

        <div>
          <h2 class="font-display font-extrabold text-xl md:text-2xl text-foreground mb-3">Data Security</h2>
          <p class="text-muted-foreground">
            We implement reasonable measures to protect the personal information you provide. However, no method of transmission over the Internet or electronic storage is 100% secure, and we cannot guarantee absolute security.
          </p>
        </div>

        <div>
          <h2 class="font-display font-extrabold text-xl md:text-2xl text-foreground mb-3">Contact Us</h2>
          <p class="text-muted-foreground">
            If you have any questions about this Privacy Policy, please contact us:
          </p>
          <ul class="mt-3 text-muted-foreground space-y-1">
            <li>Email: <a href="mailto:theredroofer@gmail.com" class="text-accent hover:underline">theredroofer@gmail.com</a></li>
            <li>Phone: <a href="tel:+19402603197" class="text-accent hover:underline">+1 940-260-3197</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
