---
import BaseLayout from '../components/layout/BaseLayout.astro';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact The Red Roofer",
  "url": "https://theredroofer.com/contact",
  "description": "Contact The Red Roofer for a free estimate on roofing, handyman, and home repair services in Little Elm, TX.",
  "mainEntity": {
    "@type": "RoofingContractor",
    "name": "The Red Roofer",
    "telephone": "+1-940-260-3197",
    "email": "theredroofer@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Little Elm",
      "addressRegion": "TX",
      "addressCountry": "US"
    }
  }
};

const whyChooseUs = [
  {
    title: "Honest Pricing",
    description: "No hidden fees or surprise charges. We give you a clear, upfront estimate before any work begins.",
    icon: "dollar",
  },
  {
    title: "Fast Response",
    description: "We know roofing issues can't wait. We respond quickly to every inquiry and get to work fast.",
    icon: "clock",
  },
  {
    title: "Quality Work",
    description: "Every job is done right the first time with premium materials and expert craftsmanship.",
    icon: "shield",
  },
  {
    title: "Licensed & Insured",
    description: "Fully licensed and insured for your peace of mind. We stand behind every project we complete.",
    icon: "badge",
  },
];
---

<BaseLayout
  title="Contact The Red Roofer | Little Elm, TX"
  description="Contact The Red Roofer for a free estimate on roofing, handyman, and home repair services in Little Elm, TX. Call +1 940-260-3197 or fill out our form."
  schemaJson={contactSchema}
>
  <!-- Hero Section -->
  <section class="bg-foreground text-background py-16 sm:py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold tracking-tight mb-4 animate-on-scroll">
        Contact Us
      </h1>
      <p class="text-lg sm:text-xl text-background/80 max-w-2xl mx-auto animate-on-scroll">
        Ready to get started? Fill out the form below or give us a call. We'll get back to you as soon as possible with a free estimate.
      </p>
    </div>
  </section>

  <!-- Contact Form & Info Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Contact Form -->
        <div class="animate-on-scroll">
          <h2 class="text-2xl sm:text-3xl font-display font-extrabold text-[hsl(149,51%,20%)] mb-6">Send Us a Message</h2>
          <form id="contact-form" class="space-y-5">
            <div>
              <label for="contact-name" class="block text-sm font-medium text-[hsl(149,51%,20%)] mb-1.5">Your Name</label>
              <input
                type="text"
                id="contact-name"
                name="name"
                placeholder="John Smith"
                required
                class="w-full px-4 py-3 border border-[hsl(89,20%,88%)] rounded-lg text-[hsl(149,51%,20%)] placeholder:text-[hsl(92,30%,35%)]/50 focus:outline-none focus:ring-2 focus:ring-[hsl(14,100%,57%)] focus:border-transparent transition-all"
              />
            </div>
            <div>
              <label for="contact-phone" class="block text-sm font-medium text-[hsl(149,51%,20%)] mb-1.5">Phone Number</label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                placeholder="(940) 555-1234"
                required
                class="w-full px-4 py-3 border border-[hsl(89,20%,88%)] rounded-lg text-[hsl(149,51%,20%)] placeholder:text-[hsl(92,30%,35%)]/50 focus:outline-none focus:ring-2 focus:ring-[hsl(14,100%,57%)] focus:border-transparent transition-all"
              />
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-medium text-[hsl(149,51%,20%)] mb-1.5">Message</label>
              <textarea
                id="contact-message"
                name="message"
                placeholder="Tell us about your project or what you need help with..."
                rows="5"
                required
                class="w-full px-4 py-3 border border-[hsl(89,20%,88%)] rounded-lg text-[hsl(149,51%,20%)] placeholder:text-[hsl(92,30%,35%)]/50 focus:outline-none focus:ring-2 focus:ring-[hsl(14,100%,57%)] focus:border-transparent transition-all resize-none"
              ></textarea>
            </div>
            <div class="space-y-3">
              <label class="flex items-start gap-2 text-sm text-[hsl(92,30%,35%)]">
                <input type="checkbox" name="consent_contact" required class="mt-1 rounded border-[hsl(89,20%,88%)] text-[hsl(14,100%,57%)] focus:ring-[hsl(14,100%,57%)]" />
                <span>I consent to being contacted by The Red Roofer regarding my inquiry.</span>
              </label>
              <label class="flex items-start gap-2 text-sm text-[hsl(92,30%,35%)]">
                <input type="checkbox" name="consent_terms" required class="mt-1 rounded border-[hsl(89,20%,88%)] text-[hsl(14,100%,57%)] focus:ring-[hsl(14,100%,57%)]" />
                <span>I agree to the terms and conditions and privacy policy.</span>
              </label>
            </div>
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center gap-2 bg-[hsl(14,100%,57%)] text-white font-extrabold uppercase tracking-tight px-6 py-3 hover:scale-[1.02] hover:shadow-lg transition-all"
            >
              Send Message
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </form>
          <p id="contact-form-status" class="mt-4 text-center text-sm hidden"></p>
        </div>

        <!-- Contact Info Cards -->
        <div class="space-y-6 animate-on-scroll">
          <h2 class="text-2xl sm:text-3xl font-display font-extrabold text-[hsl(149,51%,20%)] mb-6">Get In Touch</h2>

          <!-- Phone Card -->
          <a
            href="tel:+19402603197"
            class="flex items-start gap-4 p-5 sm:p-6 bg-white rounded-xl border border-[hsl(89,20%,88%)] hover-lift"
          >
            <div class="w-12 h-12 rounded-lg bg-[hsl(14,100%,57%)]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(14,100%,57%)]"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-display font-bold text-[hsl(149,51%,20%)]">Phone</h3>
              <p class="text-[hsl(14,100%,57%)] font-semibold">+1 (940) 260-3197</p>
              <p class="text-sm text-[hsl(92,30%,35%)] mt-1">Call us anytime during business hours</p>
            </div>
          </a>

          <!-- Email Card -->
          <a
            href="mailto:theredroofer@gmail.com"
            class="flex items-start gap-4 p-5 sm:p-6 bg-white rounded-xl border border-[hsl(89,20%,88%)] hover-lift"
          >
            <div class="w-12 h-12 rounded-lg bg-[hsl(14,100%,57%)]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(14,100%,57%)]"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-display font-bold text-[hsl(149,51%,20%)]">Email</h3>
              <p class="text-[hsl(14,100%,57%)] font-semibold">theredroofer@gmail.com</p>
              <p class="text-sm text-[hsl(92,30%,35%)] mt-1">We respond within 24 hours</p>
            </div>
          </a>

          <!-- Service Area Card -->
          <div class="flex items-start gap-4 p-5 sm:p-6 bg-white rounded-xl border border-[hsl(89,20%,88%)]">
            <div class="w-12 h-12 rounded-lg bg-[hsl(14,100%,57%)]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(14,100%,57%)]"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-display font-bold text-[hsl(149,51%,20%)]">Service Area</h3>
              <p class="text-[hsl(149,51%,20%)] font-semibold">Little Elm, TX &amp; DFW Metroplex</p>
              <p class="text-sm text-[hsl(92,30%,35%)] mt-1">Serving all of North Texas</p>
            </div>
          </div>

          <!-- Business Hours Card -->
          <div class="flex items-start gap-4 p-5 sm:p-6 bg-white rounded-xl border border-[hsl(89,20%,88%)]">
            <div class="w-12 h-12 rounded-lg bg-[hsl(14,100%,57%)]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(14,100%,57%)]"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-display font-bold text-[hsl(149,51%,20%)]">Business Hours</h3>
              <div class="mt-2 space-y-1 text-sm">
                <div class="flex justify-between gap-4">
                  <span class="text-[hsl(92,30%,35%)]">Mon - Fri</span>
                  <span class="text-[hsl(149,51%,20%)] font-medium">7:00 AM - 7:00 PM</span>
                </div>
                <div class="flex justify-between gap-4">
                  <span class="text-[hsl(92,30%,35%)]">Saturday</span>
                  <span class="text-[hsl(149,51%,20%)] font-medium">8:00 AM - 5:00 PM</span>
                </div>
                <div class="flex justify-between gap-4">
                  <span class="text-[hsl(92,30%,35%)]">Sunday</span>
                  <span class="text-[hsl(149,51%,20%)] font-medium">Closed</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-[hsl(89,30%,95%)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16 animate-on-scroll">
        <span class="text-[hsl(14,100%,57%)] font-bold text-sm uppercase tracking-wider">Why Choose Us</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold text-[hsl(149,51%,20%)] tracking-tight mt-3">
          The Red Roofer Difference
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
        <!-- Honest Pricing -->
        <div class="bg-white rounded-xl border border-[hsl(89,20%,88%)] p-6 sm:p-8 text-center animate-on-scroll hover-lift">
          <div class="w-14 h-14 mx-auto rounded-full bg-[hsl(14,100%,57%)]/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(14,100%,57%)]"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="text-lg font-display font-bold text-[hsl(149,51%,20%)] mb-2">Honest Pricing</h3>
          <p class="text-sm text-[hsl(92,30%,35%)] leading-relaxed">No hidden fees or surprise charges. We give you a clear, upfront estimate before any work begins.</p>
        </div>

        <!-- Fast Response -->
        <div class="bg-white rounded-xl border border-[hsl(89,20%,88%)] p-6 sm:p-8 text-center animate-on-scroll hover-lift">
          <div class="w-14 h-14 mx-auto rounded-full bg-[hsl(14,100%,57%)]/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(14,100%,57%)]"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="text-lg font-display font-bold text-[hsl(149,51%,20%)] mb-2">Fast Response</h3>
          <p class="text-sm text-[hsl(92,30%,35%)] leading-relaxed">We know roofing issues can't wait. We respond quickly to every inquiry and get to work fast.</p>
        </div>

        <!-- Quality Work -->
        <div class="bg-white rounded-xl border border-[hsl(89,20%,88%)] p-6 sm:p-8 text-center animate-on-scroll hover-lift">
          <div class="w-14 h-14 mx-auto rounded-full bg-[hsl(14,100%,57%)]/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(14,100%,57%)]"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
          </div>
          <h3 class="text-lg font-display font-bold text-[hsl(149,51%,20%)] mb-2">Quality Work</h3>
          <p class="text-sm text-[hsl(92,30%,35%)] leading-relaxed">Every job is done right the first time with premium materials and expert craftsmanship.</p>
        </div>

        <!-- Licensed & Insured -->
        <div class="bg-white rounded-xl border border-[hsl(89,20%,88%)] p-6 sm:p-8 text-center animate-on-scroll hover-lift">
          <div class="w-14 h-14 mx-auto rounded-full bg-[hsl(14,100%,57%)]/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(14,100%,57%)]"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          </div>
          <h3 class="text-lg font-display font-bold text-[hsl(149,51%,20%)] mb-2">Licensed & Insured</h3>
          <p class="text-sm text-[hsl(92,30%,35%)] leading-relaxed">Fully licensed and insured for your peace of mind. We stand behind every project we complete.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-foreground text-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-display font-extrabold tracking-tight mb-4 animate-on-scroll">
        Ready To Take The Next Step?
      </h2>
      <p class="text-xl sm:text-2xl text-background/80 mb-8 sm:mb-10 animate-on-scroll">
        Get A Free Quote Today!
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-on-scroll">
        <a
          href="tel:+19402603197"
          class="inline-flex items-center justify-center gap-2 bg-white text-[hsl(149,51%,20%)] font-extrabold uppercase tracking-tight px-8 py-4 hover:scale-[1.02] hover:shadow-lg transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call (940) 260-3197
        </a>
        <a
          href="#"
          onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;"
          class="inline-flex items-center justify-center gap-2 border-2 border-white text-white font-extrabold uppercase tracking-tight px-8 py-4 hover:bg-white/10 transition-all"
        >
          Back To Top
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Contact form submission
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  const contactFormStatus = document.getElementById('contact-form-status');

  if (contactForm && contactFormStatus) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(contactForm);
      const data = {
        name: formData.get('name'),
        phone: formData.get('phone'),
        message: formData.get('message'),
        source: 'contact-page-form',
      };

      try {
        const response = await fetch(
          'https://services.leadconnectorhq.com/hooks/ks0cCYzWIf2tDiYJV3vw/webhook-trigger/VwFSHBpsK7weSGkQxPIB',
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          }
        );

        if (response.ok) {
          contactFormStatus.textContent = 'Thank you! We\'ll be in touch soon.';
          contactFormStatus.className = 'mt-4 text-center text-sm text-green-600';
          contactFormStatus.classList.remove('hidden');
          contactForm.reset();
        } else {
          throw new Error('Failed to submit');
        }
      } catch (err) {
        contactFormStatus.textContent = 'Something went wrong. Please call us at (940) 260-3197.';
        contactFormStatus.className = 'mt-4 text-center text-sm text-red-600';
        contactFormStatus.classList.remove('hidden');
      }
    });
  }
</script>
