---
import BaseLayout from '../components/layout/BaseLayout.astro';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact The Red Roofer",
  "url": "https://theredroofer.com/contact",
  "description": "Contact The Red Roofer for a free roofing estimate in Little Elm, TX and the DFW metroplex.",
  "mainEntity": {
    "@type": "RoofingContractor",
    "name": "The Red Roofer",
    "telephone": "+1-940-260-3197",
    "email": "theredroofer@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Little Elm",
      "addressRegion": "TX",
      "addressCountry": "US"
    }
  }
};
---

<BaseLayout
  title="Contact Us | The Red Roofer - Little Elm, TX"
  description="Contact The Red Roofer for a free roofing estimate in Little Elm, TX and the DFW metroplex. Call +1 940-260-3197 for fast, reliable service!"
  schemaJson={contactSchema}
>
  <!-- Hero -->
  <section class="hero-gradient py-20 sm:py-24 md:py-32 relative overflow-hidden">
    <div class="absolute bottom-20 right-20 w-48 sm:w-72 h-48 sm:h-72 bg-accent/20 rounded-full blur-3xl"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 animate-on-scroll">
      <div class="max-w-3xl">
        <span class="inline-block px-3 sm:px-4 py-1 sm:py-1.5 rounded-full bg-primary-foreground/10 text-primary-foreground/90 text-xs sm:text-sm font-semibold mb-3 sm:mb-4">Get In Touch</span>
        <h1 class="font-[family-name:var(--font-display)] text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-primary-foreground mb-4 sm:mb-6">
          Contact Us
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-primary-foreground/70">
          Get in touch for a free estimate or to discuss your project.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 sm:py-20 md:py-24 section-gradient">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 animate-on-scroll">
      <div class="grid lg:grid-cols-2 gap-8 sm:gap-12">
        <!-- Form -->
        <div id="contact-form-wrapper" class="bg-foreground rounded-lg p-5 sm:p-6 md:p-8 lg:p-10 shadow-xl transition-all duration-300 hover:shadow-2xl">
          <h2 class="font-[family-name:var(--font-display)] text-xl sm:text-2xl font-extrabold text-background mb-6 sm:mb-8 text-center uppercase tracking-tight">
            Get A Free Quote
          </h2>
          <form id="contact-form" class="space-y-4 sm:space-y-5">
            <div>
              <label class="block text-xs sm:text-sm font-bold text-background mb-1.5 sm:mb-2">Full Name *</label>
              <input
                type="text"
                name="name"
                placeholder="John Smith"
                required
                class="w-full h-10 sm:h-12 px-3 sm:px-4 bg-background border-0 text-foreground placeholder:text-muted-foreground rounded-md text-sm"
              />
            </div>
            <div>
              <label class="block text-xs sm:text-sm font-bold text-background mb-1.5 sm:mb-2">Phone</label>
              <input
                type="tel"
                name="phone"
                placeholder="(808) 555-1234"
                class="w-full h-10 sm:h-12 px-3 sm:px-4 bg-background border-0 text-foreground placeholder:text-muted-foreground rounded-md text-sm"
              />
            </div>
            <div>
              <label class="block text-xs sm:text-sm font-bold text-background mb-1.5 sm:mb-2">Short message about your needs *</label>
              <textarea
                name="message"
                placeholder="**Your message goes straight to my phone, I'll get back to you as soon as I'm available**"
                rows="3"
                required
                class="w-full px-3 sm:px-4 py-2.5 sm:py-3 bg-background text-foreground placeholder:text-muted-foreground rounded-md resize-none text-sm"
              ></textarea>
            </div>
            <div class="flex items-start gap-2">
              <input
                type="checkbox"
                id="contact-marketing-consent"
                name="marketing_consent"
                required
                class="mt-0.5 sm:mt-1 w-3.5 h-3.5 sm:w-4 sm:h-4"
              />
              <label for="contact-marketing-consent" class="text-[10px] sm:text-sm text-background/80 leading-tight">
                I consent to receive marketing text messages from The Red Roofer at the phone number provided. Frequency may vary. Message & data rates may apply. Text HELP for assistance, reply STOP to opt out.
              </label>
            </div>
            <div class="flex items-start gap-2">
              <input
                type="checkbox"
                id="contact-non-marketing-consent"
                name="non_marketing_consent"
                required
                class="mt-0.5 sm:mt-1 w-3.5 h-3.5 sm:w-4 sm:h-4"
              />
              <label for="contact-non-marketing-consent" class="text-[10px] sm:text-sm text-background/80 leading-tight">
                I consent to receive non-marketing text messages from The Red Roofer about my order updates, appointment reminders, etc. Message & data rates may apply.
              </label>
            </div>
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center gap-2 whitespace-nowrap font-extrabold uppercase tracking-tight ring-offset-background transition-all duration-300 bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] h-12 px-8 text-sm"
            >
              SEND
            </button>
            <p class="text-[10px] sm:text-xs text-center text-background/70">
              By submitting, you agree to our <a href="/terms-and-conditions" class="text-accent hover:underline">Terms & Conditions</a> and <a href="/privacy-policy" class="text-accent hover:underline">Privacy Policy</a>.
            </p>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-4 sm:space-y-6">
          <div class="mb-6 sm:mb-8">
            <h2 class="font-[family-name:var(--font-display)] text-xl sm:text-2xl font-bold text-foreground mb-3 sm:mb-4">
              Get In Touch
            </h2>
            <p class="text-sm sm:text-base md:text-lg text-muted-foreground">
              Have questions? We're here to help. Give us a call or send us a message.
            </p>
          </div>

          <a
            href="tel:+19402603197"
            class="flex items-start gap-4 sm:gap-5 p-4 sm:p-6 bg-card rounded-xl sm:rounded-2xl card-shadow border border-border/50 transition-all duration-300 hover:card-shadow-hover hover:-translate-y-1 group"
          >
            <div class="w-10 h-10 sm:w-14 sm:h-14 bg-gradient-to-br from-accent/20 to-accent/5 rounded-xl sm:rounded-2xl flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 sm:w-7 sm:h-7 text-accent"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <h3 class="font-semibold text-foreground text-base sm:text-lg">Phone</h3>
              <p class="text-accent font-bold text-lg sm:text-xl">+1 940-260-3197</p>
              <p class="text-xs sm:text-sm text-muted-foreground mt-0.5 sm:mt-1">Call us anytime</p>
            </div>
          </a>

          <a
            href="mailto:theredroofer@gmail.com"
            class="flex items-start gap-4 sm:gap-5 p-4 sm:p-6 bg-card rounded-xl sm:rounded-2xl card-shadow border border-border/50 transition-all duration-300 hover:card-shadow-hover hover:-translate-y-1 group"
          >
            <div class="w-10 h-10 sm:w-14 sm:h-14 bg-gradient-to-br from-accent/20 to-accent/5 rounded-xl sm:rounded-2xl flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 sm:w-7 sm:h-7 text-accent"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            </div>
            <div>
              <h3 class="font-semibold text-foreground text-base sm:text-lg">Email</h3>
              <p class="text-accent font-bold text-sm sm:text-base break-all">theredroofer@gmail.com</p>
              <p class="text-xs sm:text-sm text-muted-foreground mt-0.5 sm:mt-1">We reply within 24 hours</p>
            </div>
          </a>

          <div class="flex items-start gap-4 sm:gap-5 p-4 sm:p-6 bg-card rounded-xl sm:rounded-2xl card-shadow border border-border/50 transition-all duration-300 hover:shadow-lg">
            <div class="w-10 h-10 sm:w-14 sm:h-14 bg-gradient-to-br from-accent/20 to-accent/5 rounded-xl sm:rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 sm:w-7 sm:h-7 text-accent"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <h3 class="font-semibold text-foreground text-base sm:text-lg">Service Area</h3>
              <p class="text-sm sm:text-base text-muted-foreground">Aubrey, TX & DFW Metroplex<br />Serving Denton, Frisco & surrounding areas</p>
            </div>
          </div>

          <div class="flex items-start gap-4 sm:gap-5 p-4 sm:p-6 bg-card rounded-xl sm:rounded-2xl card-shadow border border-border/50 transition-all duration-300 hover:shadow-lg">
            <div class="w-10 h-10 sm:w-14 sm:h-14 bg-gradient-to-br from-accent/20 to-accent/5 rounded-xl sm:rounded-2xl flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 sm:w-7 sm:h-7 text-accent"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div>
              <h3 class="font-semibold text-foreground text-base sm:text-lg">Business Hours</h3>
              <p class="text-sm sm:text-base text-muted-foreground">Mon - Fri: 7am - 6pm<br />Sat: 8am - 2pm</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-12 sm:py-16 md:py-20 bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[family-name:var(--font-display)] text-xl sm:text-2xl font-bold text-foreground mb-6 text-center">Why Choose The Red Roofer</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="bg-card p-6 rounded-xl border border-border">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-foreground mb-3 uppercase text-sm">Local & Responsive</h3>
            <p class="text-muted-foreground text-sm">Based in Aubrey, TX, we serve Little Elm and the DFW metroplex with fast response times and a deep understanding of North Texas weather and building codes.</p>
          </div>
          <div class="bg-card p-6 rounded-xl border border-border">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-foreground mb-3 uppercase text-sm">Honest Pricing</h3>
            <p class="text-muted-foreground text-sm">No hidden fees, no pressure. You'll get a clear estimate upfront. If we find issues during work, we discuss them with you before proceeding.</p>
          </div>
          <div class="bg-card p-6 rounded-xl border border-border">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-foreground mb-3 uppercase text-sm">Insurance Help</h3>
            <p class="text-muted-foreground text-sm">We understand the claims process. We document damage, provide detailed photos, and work directly with adjusters to maximize your coverage.</p>
          </div>
          <div class="bg-card p-6 rounded-xl border border-border">
            <h3 class="font-[family-name:var(--font-display)] font-bold text-foreground mb-3 uppercase text-sm">One-Stop Shop</h3>
            <p class="text-muted-foreground text-sm">Roofing, gutters, painting, handyman work, fencing, landscaping — one call covers multiple projects and saves you time coordinating contractors.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;

  if (contactForm) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(contactForm);
      const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;

      if (!formData.get('name') || !formData.get('message')) {
        alert('Please fill in all required fields.');
        return;
      }

      if (!formData.get('marketing_consent') || !formData.get('non_marketing_consent')) {
        alert('Please accept both consent checkboxes.');
        return;
      }

      submitBtn.textContent = 'Sending...';
      submitBtn.disabled = true;

      const webhookUrl = 'https://services.leadconnectorhq.com/hooks/ks0cCYzWIf2tDiYJV3vw/webhook-trigger/VwFSHBpsK7weSGkQxPIB';

      const formPayload = new URLSearchParams();
      formPayload.append('name', formData.get('name') as string);
      formPayload.append('phone', formData.get('phone') as string || '');
      formPayload.append('message', formData.get('message') as string);
      formPayload.append('source', 'Website - Contact Page Form');
      formPayload.append('timestamp', new Date().toISOString());

      try {
        await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          mode: 'no-cors',
          body: formPayload.toString(),
        });

        alert("Thank you! Your quote request has been submitted. We'll be in touch soon.");
        contactForm.reset();
      } catch (error) {
        console.error('Error submitting form:', error);
        alert('There was an error submitting your request. Please try again or call us directly.');
      } finally {
        submitBtn.textContent = 'SEND';
        submitBtn.disabled = false;
      }
    });
  }

  // Scroll to form on load
  setTimeout(() => {
    const formWrapper = document.getElementById('contact-form-wrapper');
    if (formWrapper) {
      const elementTop = formWrapper.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({ top: elementTop - 120, behavior: 'smooth' });
    }
  }, 100);
</script>
