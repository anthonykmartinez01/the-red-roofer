---
import BaseLayout from '../components/layout/BaseLayout.astro';
import wp1 from '../assets/gallery/work-preview.jpg';
import wp2 from '../assets/gallery/work-preview-2.jpg';
import wp3 from '../assets/gallery/work-preview-3.jpg';
import wp4 from '../assets/gallery/work-preview-4.jpg';
import wp5 from '../assets/gallery/work-preview-5.jpg';
import wp6 from '../assets/gallery/work-preview-6.jpg';
import wp7 from '../assets/gallery/work-preview-7.jpg';
import wp8 from '../assets/gallery/work-preview-8.jpg';
import wp9 from '../assets/gallery/work-preview-9.jpg';
import before1 from '../assets/gallery/project1-before.jpg';
import after1 from '../assets/gallery/project1-after.jpg';

const images = [
  { src: wp1.src, alt: 'Roofing project completed by The Red Roofer' },
  { src: wp2.src, alt: 'Roof repair work in Little Elm, TX' },
  { src: wp3.src, alt: 'Residential roofing installation' },
  { src: wp4.src, alt: 'Handyman project completed in DFW metroplex' },
  { src: wp5.src, alt: 'Home repair work by The Red Roofer' },
  { src: wp6.src, alt: 'Roof replacement project in Little Elm' },
  { src: wp7.src, alt: 'Professional roofing work in North Texas' },
  { src: wp8.src, alt: 'Exterior home improvement project' },
  { src: wp9.src, alt: 'Completed roofing and repair project' },
  { src: before1.src, alt: 'Before photo of roofing project' },
  { src: after1.src, alt: 'After photo of roofing project' },
];
---

<BaseLayout
  title="Project Gallery | The Red Roofer Little Elm, TX"
  description="Browse photos of roofing, handyman, and home repair projects completed by The Red Roofer in Little Elm, TX and the DFW metroplex."
>
  <!-- Hero Section -->
  <section class="bg-foreground py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-background uppercase tracking-tight">
        Our Work
      </h1>
      <p class="mt-4 text-lg md:text-xl text-background/80 max-w-2xl mx-auto">
        Quality craftsmanship you can see. Browse our completed projects across Little Elm, TX and the DFW metroplex.
      </p>
    </div>
  </section>

  <!-- Description Section -->
  <section class="py-12 md:py-16 bg-background">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg text-muted-foreground leading-relaxed">
        From roof replacements and repairs to handyman projects and home improvements, every job we take on is completed with care and attention to detail. Take a look at some of our recent work below to see the quality and professionalism we bring to every project.
      </p>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-12 md:py-16 bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {images.map((image, index) => (
          <button
            class="gallery-thumb group relative aspect-square overflow-hidden rounded-lg bg-card cursor-pointer border-0 p-0"
            data-index={index}
            data-src={image.src}
            aria-label={`View full size: ${image.alt}`}
          >
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
              width="400"
              height="400"
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 p-4"
    role="dialog"
    aria-modal="true"
    aria-label="Image lightbox"
  >
    <button
      id="lightbox-close"
      class="absolute top-4 right-4 z-10 text-white hover:text-accent transition-colors"
      aria-label="Close lightbox"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <button
      id="lightbox-prev"
      class="absolute left-4 top-1/2 -translate-y-1/2 z-10 text-white hover:text-accent transition-colors"
      aria-label="Previous image"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="size-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <button
      id="lightbox-next"
      class="absolute right-4 top-1/2 -translate-y-1/2 z-10 text-white hover:text-accent transition-colors"
      aria-label="Next image"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="size-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg"
    />
  </div>

  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-foreground">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-background uppercase tracking-tight">
        Ready to Start Your Project?
      </h2>
      <p class="mt-4 text-lg text-background/80">
        Let us bring the same quality craftsmanship to your home. Get a free, no-obligation quote today.
      </p>
      <div class="mt-8">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 bg-[hsl(14,100%,57%)] text-white font-extrabold uppercase tracking-tight px-8 py-4 rounded-lg hover:scale-[1.02] hover:shadow-lg transition-all"
        >
          Get A Free Quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLDivElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;
  const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');

  let currentIndex = 0;
  const images: { src: string; alt: string }[] = [];

  thumbs.forEach((thumb) => {
    images.push({
      src: thumb.dataset.src || '',
      alt: thumb.querySelector('img')?.alt || '',
    });
  });

  function openLightbox(index: number) {
    currentIndex = index;
    updateLightboxImage();
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function updateLightboxImage() {
    const image = images[currentIndex];
    if (image) {
      lightboxImg.src = image.src;
      lightboxImg.alt = image.alt;
    }
  }

  function showPrev() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    updateLightboxImage();
  }

  function showNext() {
    currentIndex = (currentIndex + 1) % images.length;
    updateLightboxImage();
  }

  thumbs.forEach((thumb, index) => {
    thumb.addEventListener('click', () => openLightbox(index));
  });

  closeBtn.addEventListener('click', closeLightbox);
  prevBtn.addEventListener('click', showPrev);
  nextBtn.addEventListener('click', showNext);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') showPrev();
    if (e.key === 'ArrowRight') showNext();
  });
</script>
