---
import BaseLayout from '../components/layout/BaseLayout.astro';
import wp1 from '../assets/gallery/work-preview.jpg';
import wp2 from '../assets/gallery/work-preview-2.jpg';
import wp3 from '../assets/gallery/work-preview-3.jpg';
import wp4 from '../assets/gallery/work-preview-4.jpg';
import wp5 from '../assets/gallery/work-preview-5.jpg';
import wp6 from '../assets/gallery/work-preview-6.jpg';
import wp7 from '../assets/gallery/work-preview-7.jpg';
import wp8 from '../assets/gallery/work-preview-8.jpg';
import wp9 from '../assets/gallery/work-preview-9.jpg';

const projects = [
  { id: 1, title: "Roof Replacement", description: "Complete shingle roof replacement", image: wp1.src },
  { id: 2, title: "Shingle Installation", description: "New architectural shingle installation", image: wp2.src },
  { id: 3, title: "Residential Roof", description: "Full roof installation project", image: wp3.src },
  { id: 4, title: "Roof Ridge Work", description: "Ridge cap and ventilation installation", image: wp4.src },
  { id: 5, title: "Aerial View Project", description: "Completed roof from drone view", image: wp5.src },
  { id: 6, title: "Quality Craftsmanship", description: "Professional roofing work", image: wp6.src },
  { id: 7, title: "Pipe Boot Installation", description: "Vent pipe flashing and boots", image: wp7.src },
  { id: 8, title: "Custom Home Roof", description: "Large residential roof project", image: wp8.src },
  { id: 9, title: "Complete Roof Job", description: "Full roof replacement with Red Roofer", image: wp9.src },
];
---

<BaseLayout
  title="The Red Roofer | Gallery - Our Work"
  description="Browse our portfolio of completed roofing projects. The Red Roofer delivers reliable roof repairs and quality craftsmanship across the DFW metroplex!"
>
  <!-- Hero -->
  <section class="hero-gradient py-20 sm:py-24 md:py-32 relative overflow-hidden">
    <div class="absolute bottom-10 left-20 w-48 sm:w-72 h-48 sm:h-72 bg-accent/20 blur-3xl"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 animate-on-scroll">
      <div class="max-w-3xl">
        <span class="inline-block px-3 sm:px-4 py-1 sm:py-1.5 bg-primary-foreground/10 text-primary-foreground/90 text-xs sm:text-sm font-bold uppercase tracking-widest mb-3 sm:mb-4">Our Portfolio</span>
        <h1 class="font-[family-name:var(--font-display)] text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-primary-foreground mb-4 sm:mb-6 uppercase tracking-tight">
          Our <span class="gradient-text">Work</span>
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-primary-foreground/70">
          Browse our portfolio of completed projects. Every roof tells a story of quality craftsmanship.
        </p>
      </div>
    </div>
  </section>

  <!-- About Our Work -->
  <section class="py-12 sm:py-16 md:py-20 bg-card border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h2 class="font-[family-name:var(--font-display)] text-xl sm:text-2xl font-bold text-foreground mb-4">Our Roofing Projects</h2>
      <p class="text-muted-foreground text-sm sm:text-base mb-4">
        Below is a showcase of roof installations, repairs, and home improvement projects we've completed for homeowners across Little Elm, Aubrey, Frisco, and the DFW metroplex. Every project demonstrates our commitment to quality craftsmanship, attention to detail, and customer satisfaction. From complete roof replacements to storm damage repairs, we handle every job with the professionalism and precision our customers deserve.
      </p>
      <p class="text-muted-foreground text-sm sm:text-base">
        Whether it's architectural shingles on a new residential build, emergency tarping after a hailstorm, or complex flashing work around chimneys and vents, our experienced team delivers results that last. Click any image to view it in full detail and see the quality of work you can expect from The Red Roofer.
      </p>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-16 sm:py-20 md:py-24 section-gradient">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 md:gap-6">
        {projects.map((project, index) => (
          <div
            class="group cursor-pointer animate-on-scroll"
            data-gallery-thumb
            data-index={index}
            data-src={project.image}
            data-title={project.title}
            style={`transition-delay: ${index * 60}ms`}
          >
            <div class="aspect-[4/3] bg-secondary overflow-hidden relative transition-all duration-300 group-hover:shadow-lg group-hover:-translate-y-1 border-2 border-border group-hover:border-accent">
              <img src={project.image} alt={project.title} loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modal -->
  <div
    id="gallery-modal"
    class="fixed inset-0 z-50 hidden bg-foreground/80 backdrop-blur-md items-center justify-center p-4"
  >
    <div
      id="gallery-modal-inner"
      class="bg-card max-w-2xl w-full p-5 sm:p-8 relative animate-scale-in border-2 border-border"
    >
      <button
        id="gallery-modal-close"
        class="absolute top-3 right-3 sm:top-4 sm:right-4 p-2 sm:p-2.5 hover:bg-secondary transition-colors z-10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 sm:w-5 sm:h-5"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
      <div class="aspect-video bg-secondary flex items-center justify-center overflow-hidden relative">
        <img id="gallery-modal-img" src="" alt="" class="w-full h-full object-cover" />
      </div>
    </div>
  </div>

  <!-- CTA -->
  <section class="py-16 sm:py-20 bg-card border-t border-border/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <h2 class="font-[family-name:var(--font-display)] text-2xl sm:text-3xl md:text-4xl font-bold text-foreground mb-3 sm:mb-4">
        Ready to Start <span class="gradient-text">Your Project</span>?
      </h2>
      <p class="text-sm sm:text-base md:text-lg text-muted-foreground max-w-xl mx-auto mb-6 sm:mb-8">
        Let us add your home to our gallery of satisfied customers.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 whitespace-nowrap text-base font-bold uppercase tracking-wide ring-offset-background transition-all duration-300 bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] h-12 px-8 transition-transform duration-200 hover:scale-[1.03]">
        Get Started Today
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const modal = document.getElementById('gallery-modal') as HTMLDivElement;
  const modalInner = document.getElementById('gallery-modal-inner') as HTMLDivElement;
  const modalImg = document.getElementById('gallery-modal-img') as HTMLImageElement;
  const modalClose = document.getElementById('gallery-modal-close') as HTMLButtonElement;
  const thumbs = document.querySelectorAll('[data-gallery-thumb]');

  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const src = (thumb as HTMLElement).dataset.src || '';
      const title = (thumb as HTMLElement).dataset.title || '';
      modalImg.src = src;
      modalImg.alt = title;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
</script>
