---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Roof Replacement Calculator | The Red Roofer"
  description="Get a ballpark estimate for your roof replacement project. Enter your square footage, roof pitch, and number of stories for an instant quote."
>
  <!-- Hero Section -->
  <section class="bg-primary py-8 sm:py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center justify-center w-12 h-12 sm:w-16 sm:h-16 bg-accent mb-4 sm:mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 sm:w-8 sm:h-8 text-accent-foreground"><rect width="16" height="20" x="4" y="2" rx="2"></rect><line x1="8" x2="16" y1="6" y2="6"></line><line x1="16" x2="16" y1="14" y2="18"></line><path d="M16 10h.01"></path><path d="M12 10h.01"></path><path d="M8 10h.01"></path><path d="M12 14h.01"></path><path d="M8 14h.01"></path><path d="M12 18h.01"></path><path d="M8 18h.01"></path></svg>
        </div>
        <h1 class="font-[family-name:var(--font-display)] font-extrabold text-2xl sm:text-3xl md:text-4xl lg:text-5xl text-primary-foreground uppercase tracking-tight mb-2 sm:mb-4">
          Roof Replacement Calculator
        </h1>
        <p class="text-primary-foreground/80 text-sm sm:text-lg md:text-xl">
          Get a ballpark estimate in seconds
        </p>
      </div>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="py-6 sm:py-12 md:py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-4 sm:gap-6 md:gap-8">
          <!-- Input Card -->
          <div class="border-2 border-border rounded-xl bg-card">
            <div class="p-4 sm:p-6">
              <h2 class="font-[family-name:var(--font-display)] font-extrabold text-lg sm:text-xl uppercase tracking-tight">
                Enter Your Roof Details
              </h2>
              <p class="text-xs sm:text-sm text-muted-foreground mt-1.5">
                Fill in the information below to get your estimate
              </p>
            </div>
            <div class="p-4 sm:p-6 pt-0 sm:pt-0 space-y-4 sm:space-y-6">
              <div class="space-y-2">
                <label for="sqft" class="flex items-center gap-2 font-bold uppercase tracking-tight text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent"><path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"></path><path d="m14.5 12.5 2-2"></path></svg>
                  Square Footage *
                </label>
                <input id="sqft" type="number" inputmode="numeric" placeholder="e.g., 2000" class="w-full border-2 border-border h-12 text-base px-3 rounded-md bg-background" />
                <p class="text-xs text-muted-foreground">Total roof area in square feet</p>
              </div>

              <div class="space-y-2">
                <label for="pitch" class="flex items-center gap-2 font-bold uppercase tracking-tight text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                  Roof Pitch/Slope
                </label>
                <select id="pitch" class="w-full border-2 border-border h-12 text-base px-3 rounded-md bg-background">
                  <option value="4/12">4/12 (Low slope)</option>
                  <option value="5/12">5/12</option>
                  <option value="6/12" selected>6/12 (Standard)</option>
                  <option value="7/12">7/12 (Standard)</option>
                  <option value="8/12">8/12</option>
                  <option value="9/12">9/12</option>
                  <option value="10/12">10/12 (Steep)</option>
                  <option value="11/12">11/12 (Steep)</option>
                  <option value="12/12">12/12 (Very Steep)</option>
                </select>
                <p class="text-xs text-muted-foreground">6/12 and 7/12 are standard. Steeper = more cost.</p>
              </div>

              <div class="space-y-2">
                <label for="stories" class="flex items-center gap-2 font-bold uppercase tracking-tight text-xs sm:text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-accent"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"></path><path d="m22.54 12.43-8.58 3.91a2 2 0 0 1-1.66 0L3.46 12.43"></path><path d="m22.54 17.43-8.58 3.91a2 2 0 0 1-1.66 0L3.46 17.43"></path></svg>
                  Number of Stories
                </label>
                <select id="stories" class="w-full border-2 border-border h-12 text-base px-3 rounded-md bg-background">
                  <option value="1" selected>1 Story</option>
                  <option value="2">2 Stories</option>
                  <option value="3">3+ Stories</option>
                </select>
                <p class="text-xs text-muted-foreground">Higher buildings require more equipment.</p>
              </div>

              <div class="flex gap-3 pt-2 sm:pt-4">
                <button id="calc-btn" disabled class="flex-1 h-12 sm:h-11 text-sm sm:text-base inline-flex items-center justify-center gap-2 whitespace-nowrap font-bold uppercase tracking-wide bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg transition-all duration-300 disabled:opacity-50">
                  Calculate Estimate
                </button>
                <button id="reset-btn" class="hidden h-12 sm:h-11 inline-flex items-center justify-center gap-2 whitespace-nowrap font-bold uppercase tracking-wide border-2 border-primary bg-transparent text-primary rounded-md hover:bg-primary hover:text-primary-foreground hover:scale-[1.02] hover:shadow-lg transition-all duration-300 px-5 py-2 text-sm">
                  Reset
                </button>
              </div>
            </div>
          </div>

          <!-- Results Card -->
          <div id="results-card" class="border-2 border-border rounded-xl bg-card hidden md:block">
            <div class="p-4 sm:p-6">
              <h2 class="font-[family-name:var(--font-display)] font-extrabold text-lg sm:text-xl uppercase tracking-tight">Your Estimate</h2>
              <p class="text-xs sm:text-sm text-muted-foreground mt-1.5">Ballpark pricing based on your inputs</p>
            </div>
            <div class="p-4 sm:p-6 pt-0 sm:pt-0">
              <div id="results-empty" class="text-center py-8 sm:py-12">
                <div class="inline-flex items-center justify-center w-12 h-12 sm:w-16 sm:h-16 bg-muted mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 sm:w-8 sm:h-8 text-muted-foreground"><rect width="16" height="20" x="4" y="2" rx="2"></rect><line x1="8" x2="16" y1="6" y2="6"></line><line x1="16" x2="16" y1="14" y2="18"></line><path d="M16 10h.01"></path><path d="M12 10h.01"></path><path d="M8 10h.01"></path><path d="M12 14h.01"></path><path d="M8 14h.01"></path><path d="M12 18h.01"></path><path d="M8 18h.01"></path></svg>
                </div>
                <p class="text-muted-foreground text-sm">Enter your roof details and click "Calculate" to see your estimate</p>
              </div>
              <div id="results-content" class="hidden space-y-4 sm:space-y-6">
                <div class="text-center py-6 sm:py-8 bg-background border-2 border-border">
                  <p class="text-xs sm:text-sm font-bold uppercase tracking-tight text-muted-foreground mb-2">Estimated Cost</p>
                  <p id="estimate-range" class="font-[family-name:var(--font-display)] font-extrabold text-2xl sm:text-3xl md:text-4xl text-accent"></p>
                </div>
                <div class="space-y-1 sm:space-y-2 text-xs sm:text-sm">
                  <div class="flex justify-between py-2 border-b border-border"><span class="text-muted-foreground">Square Footage:</span><span id="summary-sqft" class="font-bold"></span></div>
                  <div class="flex justify-between py-2 border-b border-border"><span class="text-muted-foreground">Roof Pitch:</span><span id="summary-pitch" class="font-bold"></span></div>
                  <div class="flex justify-between py-2 border-b border-border"><span class="text-muted-foreground">Stories:</span><span id="summary-stories" class="font-bold"></span></div>
                  <div class="flex justify-between py-2"><span class="text-muted-foreground">Squares:</span><span id="summary-squares" class="font-bold"></span></div>
                </div>
                <div class="bg-muted p-3 sm:p-4 text-xs sm:text-sm">
                  <p class="font-bold text-foreground mb-1">This is a ballpark estimate</p>
                  <p class="text-muted-foreground">Final pricing depends on roof condition and materials. Send us pictures for accuracy!</p>
                </div>
                <div class="space-y-2 sm:space-y-3">
                  <a href="/contact" class="w-full h-12 sm:h-11 inline-flex items-center justify-center gap-2 font-bold uppercase tracking-wide bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-lg transition-all duration-300 text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-2"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg>
                    Get Accurate Quote
                  </a>
                  <a href="tel:+19402603197" class="w-full h-12 sm:h-11 inline-flex items-center justify-center gap-2 font-bold uppercase tracking-wide border-2 border-primary bg-transparent text-primary rounded-md hover:bg-primary hover:text-primary-foreground hover:scale-[1.02] hover:shadow-lg transition-all duration-300 text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    Call Us Now
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-6 sm:mt-12 grid grid-cols-2 gap-2 sm:gap-6">
          <div class="text-center p-3 sm:p-6 bg-muted">
            <p class="font-[family-name:var(--font-display)] font-extrabold text-lg sm:text-2xl text-accent mb-1 sm:mb-2">6-7/12</p>
            <p class="text-[10px] sm:text-sm text-muted-foreground font-bold uppercase tracking-tight">Standard Pitch</p>
            <p class="text-[9px] sm:text-xs text-muted-foreground mt-0.5 sm:mt-1">No extra cost</p>
          </div>
          <div class="text-center p-3 sm:p-6 bg-muted">
            <p class="font-[family-name:var(--font-display)] font-extrabold text-lg sm:text-2xl text-accent mb-1 sm:mb-2">Free</p>
            <p class="text-[10px] sm:text-sm text-muted-foreground font-bold uppercase tracking-tight">Quotes</p>
            <p class="text-[9px] sm:text-xs text-muted-foreground mt-0.5 sm:mt-1">Send pics</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Educational Info -->
  <section class="py-12 sm:py-16 md:py-20 bg-card border-b border-border/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-[family-name:var(--font-display)] text-xl sm:text-2xl font-bold text-foreground mb-6">Understanding Roof Replacement Costs</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-foreground mb-2 uppercase text-sm">What Affects Your Price</h3>
            <ul class="text-muted-foreground text-sm space-y-2">
              <li><strong>Square Footage:</strong> Measured in "squares" (100 sq ft = 1 square)</li>
              <li><strong>Roof Pitch:</strong> Steeper roofs require more labor and safety equipment</li>
              <li><strong>Stories:</strong> Higher buildings need extra equipment and rigging</li>
              <li><strong>Materials:</strong> Quality shingles rated for North Texas hail and wind</li>
              <li><strong>Deck Condition:</strong> Damage underneath increases replacement costs</li>
            </ul>
          </div>
          <div>
            <h3 class="font-[family-name:var(--font-display)] font-bold text-foreground mb-2 uppercase text-sm">Why Get a Professional Quote</h3>
            <p class="text-muted-foreground text-sm mb-3">This calculator provides a ballpark estimate, but your actual cost depends on factors only visible during a thorough inspection.</p>
            <p class="text-muted-foreground text-sm">Our inspectors check for wood rot, decking damage, improper underlayment, and other hidden issues that affect labor time and material needs. That's why we always recommend sending photos or scheduling a free in-person inspection before making a decision.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10 sm:py-16 bg-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-[family-name:var(--font-display)] font-extrabold text-xl sm:text-2xl md:text-3xl text-primary-foreground uppercase tracking-tight mb-3 sm:mb-4">Want a More Accurate Estimate?</h2>
      <p class="text-primary-foreground/80 text-sm sm:text-base max-w-2xl mx-auto mb-6 sm:mb-8">Send us pictures of your roof for a detailed, personalized quote.</p>
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 font-bold uppercase tracking-wide bg-accent text-accent-foreground rounded-md hover:bg-accent/90 hover:scale-[1.02] hover:shadow-xl transition-all duration-300 h-12 sm:h-14 px-8 text-base">
          Get Free Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 ml-2"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </a>
        <a href="tel:+19402603197" class="inline-flex items-center justify-center gap-2 font-bold uppercase tracking-wide border-2 border-primary-foreground/40 bg-transparent text-primary-foreground rounded-md hover:bg-primary-foreground/10 hover:border-primary-foreground/60 hover:scale-[1.02] transition-all duration-300 h-12 sm:h-14 px-8 text-base">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          +1 940-260-3197
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const PRICE_LOW = 375;
  const PRICE_HIGH = 400;
  const PITCH: Record<string, number> = {"4/12":1.0,"5/12":1.0,"6/12":1.0,"7/12":1.0,"8/12":1.05,"9/12":1.10,"10/12":1.15,"11/12":1.20,"12/12":1.25};
  const STORY: Record<string, number> = {"1":1.0,"2":1.10,"3":1.20};

  const sqftInput = document.getElementById('sqft') as HTMLInputElement;
  const pitchSelect = document.getElementById('pitch') as HTMLSelectElement;
  const storiesSelect = document.getElementById('stories') as HTMLSelectElement;
  const calcBtn = document.getElementById('calc-btn') as HTMLButtonElement;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
  const resultsCard = document.getElementById('results-card') as HTMLDivElement;
  const resultsEmpty = document.getElementById('results-empty') as HTMLDivElement;
  const resultsContent = document.getElementById('results-content') as HTMLDivElement;

  sqftInput.addEventListener('input', () => { calcBtn.disabled = !sqftInput.value; });

  calcBtn.addEventListener('click', () => {
    const sqft = parseFloat(sqftInput.value);
    if (isNaN(sqft) || sqft <= 0) return;
    const squares = (sqft * 1.10) / 100;
    const pm = PITCH[pitchSelect.value] || 1.0;
    const sm = STORY[storiesSelect.value] || 1.0;
    const low = Math.round(squares * PRICE_LOW * pm * sm);
    const high = Math.round(squares * PRICE_HIGH * pm * sm);

    (document.getElementById('estimate-range') as HTMLElement).textContent = `$${low.toLocaleString()} – $${high.toLocaleString()}`;
    (document.getElementById('summary-sqft') as HTMLElement).textContent = `${sqft.toLocaleString()} sq ft`;
    (document.getElementById('summary-pitch') as HTMLElement).textContent = pitchSelect.value;
    (document.getElementById('summary-stories') as HTMLElement).textContent = storiesSelect.value;
    (document.getElementById('summary-squares') as HTMLElement).textContent = (sqft / 100).toFixed(1);

    resultsEmpty.classList.add('hidden');
    resultsContent.classList.remove('hidden');
    resultsCard.classList.remove('hidden');
    resultsCard.classList.remove('border-border');
    resultsCard.classList.add('border-accent', 'bg-accent/5');
    resetBtn.classList.remove('hidden');
  });

  resetBtn.addEventListener('click', () => {
    sqftInput.value = '';
    pitchSelect.value = '6/12';
    storiesSelect.value = '1';
    resultsEmpty.classList.remove('hidden');
    resultsContent.classList.add('hidden');
    resultsCard.classList.add('border-border');
    resultsCard.classList.remove('border-accent', 'bg-accent/5');
    resetBtn.classList.add('hidden');
    calcBtn.disabled = true;
    if (window.innerWidth < 768) resultsCard.classList.add('hidden');
  });
</script>
